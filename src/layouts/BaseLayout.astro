---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  canonicalURL?: string;
  hreflangEn?: string;
  hreflangDe?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'en',
  canonicalURL = Astro.url.href,
  hreflangEn,
  hreflangDe,
  ogImage = '/og-default.jpg',
} = Astro.props;

const isDE = lang === 'de';
const navLinks = isDE
  ? [
      { href: '/de/leistungen', label: 'Leistungen' },
      { href: '/de/ueber-uns', label: 'Über uns' },
      { href: '/de/kontakt', label: 'Kontakt' },
    ]
  : [
      { href: '/services', label: 'Services' },
      { href: '/about', label: 'About' },
      { href: '/contact', label: 'Contact' },
    ];

const langSwitchHref = isDE ? '/' : '/de';
const langSwitchLabel = isDE ? 'EN' : 'DE';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang for EN/DE -->
    {hreflangEn && <link rel="alternate" hreflang="en" href={hreflangEn} />}
    {hreflangDe && <link rel="alternate" hreflang="de" href={hreflangDe} />}
    {hreflangEn && hreflangDe && <link rel="alternate" hreflang="x-default" href={hreflangEn} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />

    <!-- Structured Data: Organisation -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Sabine — Workplace Risk & Ergonomics Consultancy",
      "description": "Boutique workplace risk and ergonomics consultancy for remote-first SMEs in the UK, Ireland, DACH region, and Australia.",
      "url": "https://example.com",
      "areaServed": ["GB", "IE", "DE", "AT", "CH", "AU"],
      "knowsLanguage": ["en", "de"],
      "serviceType": "Workplace Risk Consultancy"
    })} />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <!-- Navigation -->
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-sm">
      <div class="container-wide">
        <nav class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href={isDE ? '/de' : '/'} class="flex items-center gap-3 group">
            <div class="w-8 h-8 bg-brand-accent rounded-sm flex items-center justify-center">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="5" height="5" fill="white" opacity="0.9"/>
                <rect x="9" y="2" width="5" height="5" fill="white" opacity="0.6"/>
                <rect x="2" y="9" width="5" height="5" fill="white" opacity="0.6"/>
                <rect x="9" y="9" width="5" height="5" fill="white" opacity="0.9"/>
              </svg>
            </div>
            <div>
              <span class="font-serif font-semibold text-brand-dark text-base leading-tight block">Sabine</span>
              <span class="text-xs text-slate-500 leading-tight block tracking-wide">Workplace Risk Consultancy</span>
            </div>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-8">
            {navLinks.map(link => (
              <a href={link.href} class="text-sm font-medium text-slate-600 hover:text-brand-accent transition-colors duration-150 tracking-wide">
                {link.label}
              </a>
            ))}
            <a href={langSwitchHref} class="text-xs font-semibold text-slate-400 hover:text-brand-accent border border-slate-200 px-2.5 py-1 rounded-sm transition-colors duration-150 tracking-widest uppercase">
              {langSwitchLabel}
            </a>
            <a href={isDE ? '/de/kontakt' : '/contact'} class="btn-primary text-xs py-2 px-5">
              {isDE ? 'Anfrage stellen' : 'Book a Consultation'}
            </a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600" aria-label="Open menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
        </nav>

        <!-- Mobile Nav -->
        <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-slate-100 pt-4">
          {navLinks.map(link => (
            <a href={link.href} class="block py-2 text-sm font-medium text-slate-600 hover:text-brand-accent">
              {link.label}
            </a>
          ))}
          <div class="flex items-center gap-4 mt-4">
            <a href={langSwitchHref} class="text-xs font-semibold text-slate-400 border border-slate-200 px-2.5 py-1 rounded-sm uppercase tracking-widest">
              {langSwitchLabel}
            </a>
            <a href={isDE ? '/de/kontakt' : '/contact'} class="btn-primary text-xs py-2 px-5">
              {isDE ? 'Anfrage stellen' : 'Book a Consultation'}
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-brand-dark text-white mt-24">
      <div class="container-wide py-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-7 h-7 bg-brand-accent rounded-sm flex items-center justify-center">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="2" y="2" width="5" height="5" fill="white" opacity="0.9"/>
                  <rect x="9" y="2" width="5" height="5" fill="white" opacity="0.6"/>
                  <rect x="2" y="9" width="5" height="5" fill="white" opacity="0.6"/>
                  <rect x="9" y="9" width="5" height="5" fill="white" opacity="0.9"/>
                </svg>
              </div>
              <span class="font-serif font-semibold text-white">Sabine</span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed">
              Workplace Risk & Ergonomics Consultancy for remote-first SMEs. Serving the UK, Ireland, DACH region, and Australia.
            </p>
          </div>

          <!-- Services -->
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-brand-accentLight mb-4">Services</h3>
            <ul class="space-y-2">
              {isDE ? (
                <>
                  <li><a href="/de/leistungen/ergonomische-gefaehrdungsbeurteilung" class="text-slate-400 text-sm hover:text-white transition-colors">Ergonomische Gefährdungsbeurteilung</a></li>
                  <li><a href="/de/leistungen/arbeitsschutz-audit" class="text-slate-400 text-sm hover:text-white transition-colors">Arbeitsschutz-Audit</a></li>
                  <li><a href="/de/leistungen/arbeitsschutz-retainer" class="text-slate-400 text-sm hover:text-white transition-colors">Arbeitsschutz-Retainer</a></li>
                </>
              ) : (
                <>
                  <li><a href="/services/remote-ergonomic-assessment" class="text-slate-400 text-sm hover:text-white transition-colors">Remote Ergonomic Assessment</a></li>
                  <li><a href="/services/sme-risk-audit" class="text-slate-400 text-sm hover:text-white transition-colors">SME Workplace Risk Audit</a></li>
                  <li><a href="/services/workplace-risk-retainer" class="text-slate-400 text-sm hover:text-white transition-colors">Workplace Risk Retainer</a></li>
                </>
              )}
            </ul>
          </div>

          <!-- Contact & Compliance -->
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-brand-accentLight mb-4">
              {isDE ? 'Kontakt' : 'Contact'}
            </h3>
            <ul class="space-y-2 text-slate-400 text-sm">
              <li>
                <a href={isDE ? '/de/kontakt' : '/contact'} class="hover:text-white transition-colors">
                  {isDE ? 'Anfrage stellen' : 'Book a Consultation'}
                </a>
              </li>
              <li class="pt-4 text-xs text-slate-500">
                Aligned with: HSE (UK) · HSA (Ireland) · ArbSchG / ArbStättV (DE) · Safe Work Australia
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-slate-700 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
          <p class="text-slate-500 text-xs">
            &copy; {new Date().getFullYear()} Sabine — Workplace Risk & Ergonomics Consultancy. All rights reserved.
          </p>
          <div class="flex gap-6">
            <a href="/privacy-policy" class="text-slate-500 text-xs hover:text-slate-300 transition-colors">Privacy Policy</a>
            <a href="/terms" class="text-slate-500 text-xs hover:text-slate-300 transition-colors">Terms</a>
            <a href={isDE ? '/' : '/de'} class="text-slate-500 text-xs hover:text-slate-300 transition-colors uppercase tracking-widest">
              {isDE ? 'EN' : 'DE'}
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu toggle script (minimal inline JS) -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
