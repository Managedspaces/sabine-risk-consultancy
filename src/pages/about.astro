---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About Sabine Salowsky | Workplace Wellbeing Consultant";
const description = "Sabine Salowsky holds a B.Sc. in Occupational Therapy and a Diplom in Physiological Psychology. Bilingual workplace wellbeing consultant serving DACH, UK and Ireland.";

const siteURL = 'https://sabine-risk-consultancy.netlify.app';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteURL}/#sabine`,
  "name": "Sabine Salowsky",
  "jobTitle": "Workplace Wellbeing Consultant",
  "url": `${siteURL}/about`,
  "image": `${siteURL}/sabine-salowsky.webp`,
  "knowsLanguage": ["de", "en"],
  "knowsAbout": [
    "Ergonomics",
    "Workplace Wellbeing",
    "Occupational Therapy",
    "Remote Work Assessment",
    "Gefährdungsbeurteilung",
    "Biophilic Design",
    "Physiological Psychology"
  ],
  "hasCredential": [
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "degree",
      "name": "B.Sc. Ergotherapie (Occupational Therapy)",
      "recognizedBy": { "@type": "Organization", "name": "Fachhochschule Wiener Neustadt" }
    },
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "degree",
      "name": "Diplom-Biologin, Physiological Psychology",
      "recognizedBy": { "@type": "Organization", "name": "Eberhard-Karls-Universität Tübingen" }
    }
  ],
  "worksFor": { "@id": `${siteURL}/#organization` },
  "alumniOf": [
    { "@type": "EducationalOrganization", "name": "Fachhochschule Wiener Neustadt" },
    { "@type": "EducationalOrganization", "name": "Eberhard-Karls-Universität Tübingen" }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/about"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/about"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de/ueber-uns"
  breadcrumbs={[{name:'Home',url:'/'},{name:'About',url:'/about'}]}
  pageSchema={personSchema}
>

  <!-- Page Header -->
  <section class="relative bg-brand-dark py-20 md:py-28 overflow-hidden" style="min-height:380px">
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/hero-about.webp`} alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.90) 0%, rgba(10,36,99,0.75) 60%, rgba(10,36,99,0.55) 100%);"></div>
    </div>
    <div class="container-wide relative">
      <p class="section-label text-brand-accentLight mb-4">About the Consultancy</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-2xl">
        About Sabine Salowsky
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-2xl">
        Workplace risk and ergonomics specialist. Bilingual. Remote-first. Built for SMEs that need the rigour of enterprise occupational health without the complexity or cost.
      </p>
    </div>
  </section>

  <!-- About Content -->
  <section class="py-20 md:py-28 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <!-- Founder Photo -->
          <div class="bg-brand-dark rounded-sm aspect-[4/5] relative overflow-hidden mb-6">
            <img src={`${import.meta.env.BASE_URL}/sabine-salowsky.webp`} alt="Sabine Salowsky" class="w-full h-full object-cover" loading="lazy" width="400" height="400" />
            <div class="absolute bottom-6 left-6 right-6">
              <div class="bg-brand-dark/80 backdrop-blur-sm rounded-sm p-4 border border-white/10">
                <p class="font-serif text-white text-lg font-semibold">Sabine Salowsky</p>
                <p class="text-brand-accentLight text-xs mt-1">B.Sc. Ergotherapie, Dipl.-Biol.</p>
              </div>
            </div>
          </div>
          <!-- Credentials -->
          <div class="bg-white rounded-sm border border-slate-100 p-6 shadow-sm">
            <h3 class="font-serif text-base font-semibold text-brand-dark mb-4">Credentials &amp; Expertise</h3>
            <ul class="space-y-3">
              {[
                "B.Sc. Occupational Therapy (Ergotherapie)",
                "Diplom-Biologin (Physiological Psychology)",
                "Corporate Occupational Health experience (D. Swarovski KG)",
                "Research background (Max-Planck-Institut, Tübingen)",
                "Bilingual: native-level German and English",
                "Cross-jurisdictional compliance: UK, Ireland, DACH, Australia",
              ].map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-brand-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div>
          <p class="section-label mb-4">The Approach</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6 leading-tight">
            Proportionate expertise. Defensible outputs. No generic checklists.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-5">
            Effective ergonomics consultancy requires more than just a checklist. It requires a deep, scientific understanding of human physiology, cognition, and functional capacity.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            My background is rooted in this scientific rigour. I hold a <strong>B.Sc. in Occupational Therapy</strong> and a <strong>Diplom-Biologin</strong> with a specialism in Physiological Psychology. This dual qualification provides the foundation for my approach: assessing the physical and cognitive demands of the workplace through a clinical lens.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            Before establishing this consultancy, my career spanned corporate occupational health — including direct experience within the Occupational Health division of D. Swarovski KG in Austria — as well as research roles at the Max-Planck-Institut für Biologische Kybernetik and the Chair of Cognitive Neuroscience at the University of Tübingen. I have also worked extensively across clinical settings in Germany and Austria.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Today, I apply this clinical and scientific expertise to help SMEs manage their workplace risk. My bilingual capability (native German, fluent English) and multi-jurisdictional experience mean that organisations with employees across the UK, Ireland, and the DACH region can work with a single specialist who understands the physical realities of the work and the regulatory frameworks that govern it.
          </p>

          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-white rounded-sm border border-slate-100 p-5">
              <p class="font-serif text-2xl font-semibold text-brand-accent mb-1">4</p>
              <p class="text-xs text-slate-600">Regulatory frameworks covered: UK, Ireland, DACH, Australia</p>
            </div>
            <div class="bg-white rounded-sm border border-slate-100 p-5">
              <p class="font-serif text-2xl font-semibold text-brand-accent mb-1">2</p>
              <p class="text-xs text-slate-600">Languages: English and German, both at native level</p>
            </div>
          </div>

          <a href="/contact" class="btn-primary">Book a Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-20 bg-white">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <p class="section-label mb-4">The Philosophy</p>
        <blockquote class="font-serif text-2xl md:text-3xl font-medium text-brand-dark leading-relaxed mb-8">
          "Ergonomics is not a wellness initiative. It is a legal obligation, a liability management tool, and, when done properly, a genuine driver of productivity and retention."
        </blockquote>
        <p class="text-slate-600 leading-relaxed">
          Every piece of work produced by this consultancy is designed with one question in mind: would this documentation protect the client in the event of a regulatory inspection, an insurance claim, or a legal proceeding? If the answer is no, it is not finished.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Work With Sabine</p>
      <h2 class="font-serif text-3xl font-semibold text-white leading-tight mb-6">
        Let us discuss your compliance requirements.
      </h2>
      <a href="/contact" class="btn-primary text-base px-8 py-4">Book a Consultation</a>
    </div>
  </section>

</BaseLayout>
