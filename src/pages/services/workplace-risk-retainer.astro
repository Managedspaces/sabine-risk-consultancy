---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Ongoing Wellbeing Partnership | Monthly Advisory | Sabine Salowsky";
const description = "Continuous workplace wellbeing support for growing remote and hybrid teams. Monthly advisory, priority assessments, documentation updates. From €550/month. DACH, UK, Ireland.";

const siteURL = 'https://sabine-risk-consultancy.netlify.app';

const retainerServiceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${siteURL}/services/workplace-risk-retainer#service`,
  "name": "Ongoing Wellbeing Partnership",
  "url": `${siteURL}/services/workplace-risk-retainer`,
  "description": "Continuous workplace wellbeing advisory for remote and hybrid SMEs. Monthly support, priority assessments, documentation updates and regulatory currency.",
  "provider": { "@id": `${siteURL}/#organization` },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Switzerland" },
    { "@type": "Country", "name": "United Kingdom" },
    { "@type": "Country", "name": "Ireland" }
  ],
  "offers": [
    { "@type": "Offer", "name": "Essentials (up to 30 employees)", "price": "550", "priceCurrency": "GBP", "priceSpecification": { "@type": "UnitPriceSpecification", "unitText": "per month" } },
    { "@type": "Offer", "name": "Growth (31-80 employees)", "price": "850", "priceCurrency": "GBP", "priceSpecification": { "@type": "UnitPriceSpecification", "unitText": "per month" } }
  ],
  "serviceType": "Workplace Wellbeing Advisory Retainer"
};
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/services/workplace-risk-retainer"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/services/workplace-risk-retainer"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de/leistungen/arbeitsschutz-retainer"
  breadcrumbs={[{name:'Home',url:'/'},{name:'Services',url:'/services'},{name:'Ongoing Wellbeing Partnership',url:'/services/workplace-risk-retainer'}]}
  pageSchema={retainerServiceSchema}
>

  <!-- Page Header -->
  <section class="relative bg-brand-dark py-20 md:py-28 overflow-hidden" style="min-height:380px">
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/hero-retainer.webp`} alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.90) 0%, rgba(10,36,99,0.75) 60%, rgba(10,36,99,0.50) 100%);"></div>
    </div>
    <div class="container-wide relative">
      <nav class="text-xs text-slate-500 mb-8">
        <a href={`${import.meta.env.BASE_URL}/`} class="hover:text-slate-300 transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href={`${import.meta.env.BASE_URL}/services`} class="hover:text-slate-300 transition-colors">Services</a>
        <span class="mx-2">/</span>
        <span class="text-slate-400">Ongoing Wellbeing Partnership</span>
      </nav>
      <p class="section-label text-brand-accentLight mb-4">Continuous Support</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-2xl">
        Ongoing Wellbeing Partnership
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-2xl mb-8">
        Continuous workplace wellbeing support for SMEs that are growing, changing, or simply want their people looked after properly — not just at a point in time, but as an ongoing commitment.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-start">
        <a href={`${import.meta.env.BASE_URL}/contact`} class="btn-primary">Enquire About a Partnership</a>
        <div class="text-slate-400 text-sm py-3">
          <span class="font-semibold text-white">From €550 per month</span> &nbsp;|&nbsp; Rolling monthly contract
        </div>
      </div>
    </div>
  </section>

  <!-- What It Is -->
  <section class="py-20 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="section-label mb-4">Wellbeing That Grows With You</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-5">
            Your team changes. Your wellbeing programme should too.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-5">
            A single audit or batch of assessments gives you a clear picture at a point in time. But organisations are not static. People join and leave. Working arrangements shift. New offices open. Teams move to different locations. Without ongoing attention, the wellbeing environment you worked to improve begins to drift.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            The Ongoing Wellbeing Partnership provides continuous access to workplace wellbeing expertise on a monthly basis. New employees are assessed promptly as they join. Quarterly reviews keep the programme current. And you have expert support available whenever you need it — for a specific question, a new working arrangement, or a change in your team's circumstances.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Most clients begin with an SME Workplace Wellbeing Audit to establish a clear baseline, then transition to the partnership for ongoing support. This is the most effective and cost-efficient approach for growing SMEs.
          </p>
          <a href={`${import.meta.env.BASE_URL}/services/sme-risk-audit`} class="btn-outline">Start with a Wellbeing Audit</a>
        </div>
        <div class="space-y-4">
          <div class="bg-white rounded-sm border border-slate-100 p-6 shadow-sm">
            <h3 class="font-serif text-lg font-semibold text-brand-dark mb-4">What the Partnership Includes</h3>
            <ul class="space-y-3">
              {[
                "Quarterly wellbeing review and programme update",
                "New hire ergonomic assessments (up to 5 per month, additional at reduced rate)",
                "Guidance updates as your team's working arrangements change",
                "Priority email and video consultation access",
                "Annual wellbeing summary report for leadership",
                "Regulatory monitoring for UK, Ireland, DACH, and Australia",
              ].map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-brand-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-brand-dark rounded-sm p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-accentLight mb-3">Partnership Terms</p>
            <div class="space-y-2 text-xs text-slate-400">
              <p>Rolling monthly contract with 30 days notice to cancel.</p>
              <p>No minimum term. No setup fee.</p>
              <p>Onboarding call included to align on your team profile, working arrangements, and priorities.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Ongoing Matters -->
  <section class="py-20 bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="section-label mb-3">Why Ongoing Support Matters</p>
        <h2 class="font-serif text-3xl font-semibold text-brand-dark">Wellbeing is not a one-time event</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-brand-bg rounded-sm border border-slate-100">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-3">Every New Person Matters</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Every new hire joins with their own working environment, habits, and physical needs. Assessing them promptly — before poor habits become ingrained — is the most effective point of intervention.</p>
        </div>
        <div class="text-center p-8 bg-brand-bg rounded-sm border border-slate-100">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-3">Environments Change</h3>
          <p class="text-slate-600 text-sm leading-relaxed">People move house. Teams go fully remote. Offices close or open. Each change creates a new set of environmental conditions that may or may not support the people working in them.</p>
        </div>
        <div class="text-center p-8 bg-brand-bg rounded-sm border border-slate-100">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-3">Performance Compounds</h3>
          <p class="text-slate-600 text-sm leading-relaxed">The productivity gains from a well-designed working environment are not a one-off uplift. They compound over time — and so does the cost of an environment that is gradually undermining your team's health and focus.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-brand-cream">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <p class="section-label mb-3">Pricing</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark">Monthly Partnership Pricing</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-sm border border-slate-100 p-6 text-center shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Essentials</p>
            <p class="text-xs text-slate-400 mb-3">Up to 30 employees</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">€550</p>
            <p class="text-xs text-slate-500">per month</p>
            <p class="text-xs text-slate-400 mt-3">Up to 3 new hire assessments/month</p>
          </div>
          <div class="bg-white rounded-sm border border-brand-accent p-6 text-center shadow-sm relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand-accent text-white text-xs font-semibold px-3 py-1 rounded-sm uppercase tracking-wide">Most Popular</div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Growth</p>
            <p class="text-xs text-slate-400 mb-3">31 to 80 employees</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">€850</p>
            <p class="text-xs text-slate-500">per month</p>
            <p class="text-xs text-slate-400 mt-3">Up to 5 new hire assessments/month</p>
          </div>
          <div class="bg-white rounded-sm border border-slate-100 p-6 text-center shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Scale</p>
            <p class="text-xs text-slate-400 mb-3">81 to 150 employees</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">POA</p>
            <p class="text-xs text-slate-500">contact us for a quote</p>
            <p class="text-xs text-slate-400 mt-3">Unlimited new hire assessments</p>
          </div>
        </div>
        <p class="text-center text-xs text-slate-500 mt-6">All prices exclude VAT. Rolling monthly contract, 30 days notice to cancel. No setup fee.</p>
      </div>
    </div>
  </section>

  <!-- Direct with Sabine -->
  <section class="py-16 bg-brand-cream">
    <div class="container-narrow">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="flex-shrink-0">
          <img src={`${import.meta.env.BASE_URL}/sabine-salowsky.webp`} alt="Sabine Salowsky" class="w-28 h-28 rounded-sm object-cover object-top shadow-md" loading="lazy" width="400" height="400" />
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-accent mb-3">A note on how we work</p>
          <p class="font-serif text-xl font-semibold text-brand-dark mb-3">A retainer with Sabine is a relationship, not a contract.</p>
          <p class="text-slate-600 leading-relaxed">Retainer clients work directly with Sabine Salowsky, B.Sc. Ergotherapie, Dipl.-Biol. — not with a rotating team of consultants. She knows your organisation, your team, and your working patterns. When something changes, she is the person you call. This continuity of specialist knowledge is what makes an ongoing partnership genuinely valuable, rather than just a recurring invoice.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Ready to make wellbeing an ongoing commitment?</p>
      <h2 class="font-serif text-3xl font-semibold text-white leading-tight mb-6">
        Enquire about an Ongoing Wellbeing Partnership today.
      </h2>
      <a href={`${import.meta.env.BASE_URL}/contact`} class="btn-primary text-base px-8 py-4">Enquire About a Partnership</a>
    </div>
  </section>

</BaseLayout>
