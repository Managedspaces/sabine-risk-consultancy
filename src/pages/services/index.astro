---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Workplace Wellbeing Services for SMEs | Sabine Salowsky";
const description = "Ergonomic assessments, wellbeing audits and ongoing advisory for remote and hybrid SMEs. Serving Germany, Austria, Switzerland, UK and Ireland. From €295 per employee.";

const siteURL = 'https://sabine-risk-consultancy.netlify.app';

const servicesListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Workplace Wellbeing Services",
  "description": "Three focused workplace wellbeing services for remote and hybrid SMEs.",
  "url": `${siteURL}/services`,
  "numberOfItems": 3,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Remote Ergonomic Assessment",
      "url": `${siteURL}/services/remote-ergonomic-assessment`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "SME Workplace Wellbeing Audit",
      "url": `${siteURL}/services/sme-risk-audit`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Ongoing Wellbeing Partnership",
      "url": `${siteURL}/services/workplace-risk-retainer`
    }
  ]
};

const services = [
  {
    slug: "remote-ergonomic-assessment",
    title: "Remote Ergonomic Assessment",
    tagline: "Help each person work at their best",
    description: "A personalised, individually tailored assessment for employees working from home or in a hybrid arrangement. We look at the whole picture — workstation setup, posture, lighting, screen environment, and working patterns — and produce a clear, practical improvement plan so each person feels better and performs better. Regulatory documentation is included as a natural output.",
    includes: [
      "Pre-assessment questionnaire covering physical setup and wellbeing",
      "Photo or video workstation review",
      "Written improvement plan with prioritised recommendations",
      "Supporting documentation for HR records",
      "Plain-language summary for the employee to act on immediately",
    ],
    price: "From €295 per employee",
    ideal: "SMEs with remote or hybrid staff who want their people working comfortably and at full capacity",
  },
  {
    slug: "sme-risk-audit",
    title: "SME Workplace Wellbeing Audit",
    tagline: "Understand where your team is losing energy and focus",
    description: "A comprehensive review of how your remote or hybrid team actually works — covering physical environment, sensory conditions, and working patterns across your whole organisation. You receive a clear picture of where your people are losing energy, focus, and output, and a prioritised plan to change it. The output also satisfies your regulatory obligations across UK, Ireland, and DACH.",
    includes: [
      "Review of existing health and wellbeing policies",
      "Remote and hybrid workforce environment mapping",
      "Wellbeing gap analysis with prioritised improvement areas",
      "Executive summary for leadership",
      "Prioritised action plan with implementation guidance",
      "Regulatory alignment confirmation for applicable jurisdictions",
    ],
    price: "Project-based from €1,800",
    ideal: "SMEs of 20 to 150 employees who want a clear, honest picture of their team's working environment",
  },
  {
    slug: "workplace-risk-retainer",
    title: "Ongoing Wellbeing Partnership",
    tagline: "Continuous support as your team grows and changes",
    description: "A monthly partnership providing continuous access to workplace wellbeing expertise. As your team evolves — through new hires, role changes, or shifts in working arrangements — your wellbeing programme stays current and effective. Includes regular reviews, new employee assessments, and expert guidance whenever you need it, all delivered remotely.",
    includes: [
      "Quarterly wellbeing review and programme update",
      "New hire ergonomic assessments (up to 5 per month)",
      "Policy and guidance updates as your team changes",
      "Priority email and video consultation access",
      "Annual wellbeing summary report",
    ],
    price: "From €550 per month",
    ideal: "Growing SMEs who want their people supported continuously, not just at a point in time",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/services"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/services"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de/leistungen"
  breadcrumbs={[{name:'Home',url:'/'},{name:'Services',url:'/services'}]}
  pageSchema={servicesListSchema}
>

  <!-- Page Header -->
  <section class="relative bg-brand-dark py-20 md:py-28 overflow-hidden" style="min-height:380px">
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/hero-services.webp`} alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.90) 0%, rgba(10,36,99,0.75) 60%, rgba(10,36,99,0.55) 100%);"></div>
    </div>
    <div class="container-wide relative">
      <p class="section-label text-brand-accentLight mb-4">Our Services</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-2xl">
        Practical Wellbeing for Remote and Hybrid Teams
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-2xl">
        Three focused services designed to help your people work better, feel better, and stay longer. All delivered remotely, all grounded in clinical expertise, and all aligned with the regulatory standards that apply to your workforce.
      </p>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="py-20 md:py-28 bg-brand-bg">
    <div class="container-wide space-y-16">
      {services.map((service, index) => (
        <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 items-start ${index % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <div>
            <p class="section-label mb-3">{service.tagline}</p>
            <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-5">{service.title}</h2>
            <p class="text-slate-600 leading-relaxed mb-6">{service.description}</p>
            <p class="text-sm font-semibold text-brand-accent uppercase tracking-wide mb-8">{service.price}</p>
            <a href={`/services/${service.slug}`} class="btn-primary">View Full Details</a>
          </div>
          <div class="bg-white rounded-sm border border-slate-100 p-8 shadow-sm">
            <h3 class="font-serif text-lg font-semibold text-brand-dark mb-5">What is included</h3>
            <ul class="space-y-3">
              {service.includes.map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-brand-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <div class="mt-6 pt-6 border-t border-slate-100">
              <p class="text-xs text-slate-500 uppercase tracking-wide font-semibold mb-1">Ideal for</p>
              <p class="text-sm text-slate-600">{service.ideal}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Regulatory Standards — positioned as reassurance, not the lead -->
  <section class="py-16 bg-white border-t border-slate-100">
    <div class="container-wide">
      <div class="text-center mb-12">
        <p class="section-label mb-3">Built on Solid Foundations</p>
        <h2 class="font-serif text-2xl font-semibold text-brand-dark">Every service is aligned with the standards that apply to your workforce</h2>
        <p class="text-slate-500 text-sm mt-4 max-w-xl mx-auto">Regulatory compliance is a natural outcome of a well-designed wellbeing programme. Every report and assessment we produce is structured to satisfy the applicable requirements in your jurisdiction — so you never have to choose between caring for your people and meeting your legal obligations.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center p-6 border border-slate-100 rounded-sm">
          <p class="font-semibold text-brand-dark text-sm mb-1">United Kingdom</p>
          <p class="text-xs text-slate-500">HSE · DSE Regulations 1992 · Management of Health and Safety at Work Regulations</p>
        </div>
        <div class="text-center p-6 border border-slate-100 rounded-sm">
          <p class="font-semibold text-brand-dark text-sm mb-1">Ireland</p>
          <p class="text-xs text-slate-500">HSA · Safety, Health and Welfare at Work Act 2005 · Display Screen Equipment Regulations</p>
        </div>
        <div class="text-center p-6 border border-slate-100 rounded-sm">
          <p class="font-semibold text-brand-dark text-sm mb-1">Germany / DACH</p>
          <p class="text-xs text-slate-500">ArbSchG · ArbStattV · Bildschirmarbeitsverordnung · DGUV Guidance</p>
        </div>
        <div class="text-center p-6 border border-slate-100 rounded-sm">
          <p class="font-semibold text-brand-dark text-sm mb-1">Australia</p>
          <p class="text-xs text-slate-500">Safe Work Australia · Model WHS Regulations · State and Territory WHS Acts</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Not sure where to start?</p>
      <h2 class="font-serif text-3xl font-semibold text-white leading-tight mb-6">
        Book a free conversation to talk through what your team needs.
      </h2>
      <a href="/contact" class="btn-primary text-base px-8 py-4">Book a Consultation</a>
    </div>
  </section>

</BaseLayout>
