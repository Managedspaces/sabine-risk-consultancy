---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Remote Ergonomic Assessment for Home & Hybrid Workers | Sabine";
const description = "Individual remote ergonomic risk assessments aligned with UK DSE Regulations, HSA Ireland, and ArbSchG Germany. Audit-ready reports from £295 per employee.";

const faqs = [
  {
    q: "Is a remote ergonomic assessment legally sufficient under UK DSE Regulations?",
    a: "Yes. The Health and Safety (Display Screen Equipment) Regulations 1992 require employers to assess the risks posed by display screen equipment workstations, but they do not prescribe that assessments must be conducted in person. A structured remote assessment that reviews the workstation through a questionnaire and photographic evidence, and produces a written risk report, meets the regulatory requirement for documented assessment."
  },
  {
    q: "What does the employee need to provide?",
    a: "The employee completes a structured questionnaire covering their workstation setup, equipment, working patterns, and any existing discomfort. They also provide photographs of their workstation from two or three angles. The entire process typically takes the employee around 15 minutes."
  },
  {
    q: "How long does it take to receive the report?",
    a: "Reports are typically delivered within five working days of receiving the completed questionnaire and photographs. Expedited turnaround is available on request."
  },
  {
    q: "Can the assessment cover employees in multiple countries?",
    a: "Yes. Our assessments can be aligned with UK, Irish, German, Austrian, Swiss, or Australian regulatory standards. For organisations with employees across multiple jurisdictions, we produce reports that reference the applicable standard for each employee's location."
  },
  {
    q: "Do you offer volume pricing for larger teams?",
    a: "Yes. Volume pricing is available for organisations assessing five or more employees. Please contact us to discuss a package appropriate for your team size."
  }
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  hreflangEn="https://example.com/services/remote-ergonomic-assessment"
  hreflangDe="https://example.com/de/leistungen/ergonomische-gefaehrdungsbeurteilung"
>

  <!-- JSON-LD Service Schema -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Remote Ergonomic Assessment",
    "provider": {
      "@type": "ProfessionalService",
      "name": "Sabine — Workplace Risk & Ergonomics Consultancy"
    },
    "description": "Individual remote ergonomic risk assessment for home and hybrid workers. Aligned with UK DSE Regulations, HSA Ireland, and ArbSchG Germany.",
    "areaServed": ["GB", "IE", "DE", "AT", "CH", "AU"],
    "offers": {
      "@type": "Offer",
      "price": "295",
      "priceCurrency": "GBP",
      "description": "From £295 per employee"
    }
  })} />

  <!-- Page Header -->
  <section class="bg-brand-dark py-20 md:py-28">
    <div class="container-wide">
      <nav class="text-xs text-slate-500 mb-8">
        <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/services" class="hover:text-slate-300 transition-colors">Services</a>
        <span class="mx-2">/</span>
        <span class="text-slate-400">Remote Ergonomic Assessment</span>
      </nav>
      <p class="section-label text-brand-accentLight mb-4">Individual Compliance</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-2xl">
        Remote Ergonomic Assessment
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-2xl mb-8">
        A structured, individually tailored assessment for employees working from home or in a hybrid arrangement. Produces audit-ready documentation aligned with the regulatory standards that apply to your workforce.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-start">
        <a href="/contact" class="btn-primary">Request an Assessment</a>
        <div class="text-slate-400 text-sm py-3">
          <span class="font-semibold text-white">From £295</span> per employee &nbsp;|&nbsp; Reports delivered within 5 working days
        </div>
      </div>
    </div>
  </section>

  <!-- Who It's For -->
  <section class="py-20 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="section-label mb-4">Who This Service Is For</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-5">
            Your duty of care does not end at the office door.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-5">
            Under the Health and Safety (Display Screen Equipment) Regulations 1992, UK employers are required to assess the risks to employees who habitually use display screen equipment as a significant part of their normal work. This obligation applies equally to employees working from home.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            The same principle holds in Ireland under the Safety, Health and Welfare at Work (General Application) Regulations, and in Germany under the Bildschirmarbeitsverordnung and the broader Arbeitsschutzgesetz framework. In Australia, Safe Work Australia's model WHS legislation imposes equivalent duties.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Most SMEs have not conducted documented assessments for their remote employees. This creates a measurable legal and insurance exposure that our Remote Ergonomic Assessment directly addresses.
          </p>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white p-5 rounded-sm border border-slate-100">
              <p class="font-serif text-2xl font-semibold text-brand-accent mb-1">73%</p>
              <p class="text-xs text-slate-600">of UK remote workers report musculoskeletal discomfort related to their home workstation</p>
            </div>
            <div class="bg-white p-5 rounded-sm border border-slate-100">
              <p class="font-serif text-2xl font-semibold text-brand-accent mb-1">£1,200</p>
              <p class="text-xs text-slate-600">Average cost of a single musculoskeletal absence claim to an employer, before legal costs</p>
            </div>
          </div>
        </div>
        <div class="space-y-6">
          <div class="bg-white rounded-sm border border-slate-100 p-8 shadow-sm">
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-5">What the Assessment Includes</h3>
            <ul class="space-y-4">
              {[
                ["Pre-assessment questionnaire", "A structured questionnaire covering workstation setup, equipment, working patterns, lighting, and any existing discomfort or symptoms."],
                ["Photographic workstation review", "The employee submits photographs of their workstation. We review posture risk, equipment positioning, and environmental factors."],
                ["Written risk report", "A clear, individually tailored report identifying risks, their severity, and prioritised recommendations for improvement."],
                ["Audit-ready documentation", "The report is formatted for inclusion in your compliance records and is suitable for HR, insurance, and regulatory purposes."],
                ["Employee summary", "A plain-language summary for the employee explaining the findings and recommended actions."],
              ].map(([title, desc]) => (
                <li class="flex items-start gap-3">
                  <svg class="w-4 h-4 text-brand-accent mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  <div>
                    <p class="text-sm font-semibold text-brand-dark">{title}</p>
                    <p class="text-xs text-slate-500 mt-0.5">{desc}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-brand-dark rounded-sm p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-accentLight mb-3">Regulatory Alignment</p>
            <div class="space-y-2 text-xs text-slate-400">
              <p><span class="text-white font-medium">UK:</span> Health and Safety (DSE) Regulations 1992</p>
              <p><span class="text-white font-medium">Ireland:</span> Safety, Health and Welfare at Work (General Application) Regulations</p>
              <p><span class="text-white font-medium">Germany:</span> Bildschirmarbeitsverordnung · ArbSchG · ArbStattV</p>
              <p><span class="text-white font-medium">Australia:</span> Safe Work Australia Model WHS Regulations</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="section-label mb-3">The Process</p>
        <h2 class="font-serif text-3xl font-semibold text-brand-dark">How It Works</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {[
          ["1", "Enquiry", "You contact us with your team size and jurisdiction. We confirm the appropriate regulatory framework and provide a quote."],
          ["2", "Questionnaire", "Each employee completes a structured questionnaire and submits photographs of their workstation. This takes approximately 15 minutes."],
          ["3", "Assessment", "We review the submissions, assess risk factors, and prepare individually tailored written reports for each employee."],
          ["4", "Delivery", "Reports are delivered within five working days. You receive both the employer compliance documentation and the individual employee summaries."],
        ].map(([num, title, desc]) => (
          <div class="text-center">
            <div class="w-10 h-10 bg-brand-accent text-white font-serif font-semibold text-lg rounded-sm flex items-center justify-center mx-auto mb-4">{num}</div>
            <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">{title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-20 bg-brand-cream">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <p class="section-label mb-3">Pricing</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark">Transparent, Proportionate Pricing</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-sm border border-slate-100 p-6 text-center shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Single Employee</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">£295</p>
            <p class="text-xs text-slate-500">per employee</p>
          </div>
          <div class="bg-white rounded-sm border border-brand-accent p-6 text-center shadow-sm relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand-accent text-white text-xs font-semibold px-3 py-1 rounded-sm uppercase tracking-wide">Best Value</div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">5 to 20 Employees</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">£245</p>
            <p class="text-xs text-slate-500">per employee</p>
          </div>
          <div class="bg-white rounded-sm border border-slate-100 p-6 text-center shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">21+ Employees</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">POA</p>
            <p class="text-xs text-slate-500">contact us for a quote</p>
          </div>
        </div>
        <p class="text-center text-xs text-slate-500 mt-6">All prices exclude VAT. Reports delivered within 5 working days. Expedited turnaround available on request.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-white">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <p class="section-label mb-3">Frequently Asked Questions</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark">Common Questions</h2>
        </div>
        <div class="space-y-6">
          {faqs.map(faq => (
            <div class="border-b border-slate-100 pb-6">
              <h3 class="font-serif text-lg font-semibold text-brand-dark mb-3">{faq.q}</h3>
              <p class="text-slate-600 text-sm leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Ready to protect your remote workforce?</p>
      <h2 class="font-serif text-3xl font-semibold text-white leading-tight mb-6">
        Request a Remote Ergonomic Assessment today.
      </h2>
      <a href="/contact" class="btn-primary text-base px-8 py-4">Request an Assessment</a>
    </div>
  </section>

</BaseLayout>
