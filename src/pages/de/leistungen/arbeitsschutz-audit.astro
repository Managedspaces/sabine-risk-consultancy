---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Wohlbefindens-Analyse für KMU | Sabine Salowsky";
const description = "Umfassende Wohlbefindens-Analyse für Remote- und Hybrid-KMU in Deutschland, Österreich und der Schweiz. Priorisierter Verbesserungsplan inklusive. Ab 2.100 €.";

const siteURL = 'https://sabine-risk-consultancy.netlify.app';

const deAuditSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": `${siteURL}/de/leistungen/arbeitsschutz-audit#service`,
  "name": "Wohlbefindens-Analyse für KMU",
  "url": `${siteURL}/de/leistungen/arbeitsschutz-audit`,
  "description": "Umfassende Wohlbefindens-Analyse für KMU mit Remote- und Hybrid-Belegschaft. Umgebungsanalyse, Lückenanalyse, priorisierter Verbesserungsplan und gesetzliche Ausrichtung.",
  "provider": { "@id": `${siteURL}/#organization` },
  "areaServed": [
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "offers": [
    { "@type": "Offer", "name": "Kleines Team (bis 30 Mitarbeiter)", "price": "2100", "priceCurrency": "EUR" },
    { "@type": "Offer", "name": "Mittleres Team (31-100 Mitarbeiter)", "price": "3300", "priceCurrency": "EUR" }
  ],
  "serviceType": "Wohlbefindens-Audit",
  "inLanguage": "de-DE"
};
---

<BaseLayout
  title={title}
  description={description}
  lang="de"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/de/leistungen/arbeitsschutz-audit"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/services/sme-risk-audit"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de/leistungen/arbeitsschutz-audit"
  breadcrumbs={[{name:'Startseite',url:'/de'},{name:'Leistungen',url:'/de/leistungen'},{name:'Wohlbefindens-Analyse für KMU',url:'/de/leistungen/arbeitsschutz-audit'}]}
  pageSchema={deAuditSchema}
>

  <section class="bg-brand-dark py-20 md:py-28">
    <div class="container-wide">
      <nav class="text-xs text-slate-500 mb-8">
        <a href={`${import.meta.env.BASE_URL}/de`} class="hover:text-slate-300 transition-colors">Startseite</a>
        <span class="mx-2">/</span>
        <a href={`${import.meta.env.BASE_URL}/de/leistungen`} class="hover:text-slate-300 transition-colors">Leistungen</a>
        <span class="mx-2">/</span>
        <span class="text-slate-400">Arbeitsschutz-Audit</span>
      </nav>
      <p class="section-label text-brand-accentLight mb-4">Umfassende Compliance</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-2xl">
        Arbeitsschutz-Audit für KMU
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-2xl mb-8">
        Strukturierte, projektbasierte Analyse Ihrer gesamten Arbeitsschutz-Compliance. Richtlinienprüfung, Risikomatrix, Massnahmenplan und Ausrichtung an ArbSchG, ArbStättV und DGUV-Vorgaben.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 items-start">
        <a href={`${import.meta.env.BASE_URL}/de/kontakt`} class="btn-primary">Audit anfragen</a>
        <div class="text-slate-400 text-sm py-3">
          <span class="font-semibold text-white">Ab 2.100 EUR</span> &nbsp;|&nbsp; Projektbasiert, Festpreis
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="section-label mb-4">Was das Audit umfasst</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-5">
            Eine Compliance-Basis, die einer Prüfung standhält.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-5">
            Das Arbeitsschutz-Audit für KMU ist eine umfassende Analyse Ihrer aktuellen Compliance-Situation im Bereich Arbeitsschutz, mit besonderem Fokus auf die Risiken durch Remote- und Hybrid-Arbeit. Es richtet sich an KMU, die schnell gewachsen sind, ihr Arbeitsmodell geändert haben oder noch nie eine formelle Compliance-Überprüfung durchgeführt haben.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            Das Audit prüft Ihre bestehende Dokumentation, bewertet die Lücke zwischen Ihrem aktuellen Stand und den geltenden gesetzlichen Anforderungen und erstellt eine strukturierte Risikomatrix mit einem priorisierten Massnahmenplan. Das Ergebnis ist geeignet für die Vorlage bei Ihrer Geschäftsführung, Ihrem Versicherer und jeder Aufsichtsbehörde.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Alle Arbeiten werden vollständig digital durchgeführt. Keine Betriebsbegehungen erforderlich, was die Kosten verhältnismässig hält und die Lieferung beschleunigt.
          </p>
        </div>
        <div class="bg-white rounded-sm border border-slate-100 p-8 shadow-sm">
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-6">Audit-Ergebnisse</h3>
          <ul class="space-y-4">
            {[
              ["Richtlinienprüfungs-Zusammenfassung", "Bewertung Ihrer bestehenden Arbeitsschutzrichtlinien anhand der geltenden gesetzlichen Anforderungen."],
              ["Belegschafts-Risikokarte", "Strukturierte Übersicht Ihrer Remote- und Hybrid-Belegschaftsrisiken nach Rollentyp und Standort."],
              ["Risikomatrix", "Priorisierte Matrix mit Eintrittswahrscheinlichkeit, Schwere und empfohlenen Massnahmen für jedes identifizierte Risiko."],
              ["Management-Summary", "Prägnantes Briefing-Dokument für Geschäftsführung, Beirat oder Investoren."],
              ["Priorisierter Massnahmenplan", "Sequenzierte Liste empfohlener Massnahmen mit Umsetzungshinweisen und vorgeschlagenen Zeitplänen."],
              ["Ausrichtungsbericht", "Bestätigung der Ausrichtung (oder Lücken) an ArbSchG, ArbStättV und DGUV-Vorgaben."],
            ].map(([title, desc]) => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-brand-accent mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                <div>
                  <p class="text-sm font-semibold text-brand-dark">{title}</p>
                  <p class="text-xs text-slate-500 mt-0.5">{desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-cream">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <p class="section-label mb-3">Preise</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark">Festpreise, projektbasiert</h2>
          <p class="text-slate-600 text-sm mt-4 max-w-xl mx-auto">Alle Audits werden zu Festpreisen angeboten. Sie erhalten ein bestätigtes Angebot, bevor mit der Arbeit begonnen wird. Keine Stundensätze, keine unerwarteten Zusatzkosten.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-sm border border-slate-100 p-6 text-center shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Kleines Team</p>
            <p class="text-xs text-slate-400 mb-3">Bis 30 Mitarbeiter</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">2.100 EUR</p>
            <p class="text-xs text-slate-500">Festpreis</p>
          </div>
          <div class="bg-white rounded-sm border border-brand-accent p-6 text-center shadow-sm relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-brand-accent text-white text-xs font-semibold px-3 py-1 rounded-sm uppercase tracking-wide">Am häufigsten</div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Mittleres Team</p>
            <p class="text-xs text-slate-400 mb-3">31 bis 100 Mitarbeiter</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">3.300 EUR</p>
            <p class="text-xs text-slate-500">Festpreis</p>
          </div>
          <div class="bg-white rounded-sm border border-slate-100 p-6 text-center shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 mb-2">Grösseres Team</p>
            <p class="text-xs text-slate-400 mb-3">101 bis 150 Mitarbeiter</p>
            <p class="font-serif text-3xl font-semibold text-brand-dark mb-1">Auf Anfrage</p>
            <p class="text-xs text-slate-500">Angebot auf Anfrage</p>
          </div>
        </div>
        <p class="text-center text-xs text-slate-500 mt-6">Alle Preise zzgl. MwSt. Audits über mehrere Jurisdiktionen können einen Aufpreis erfordern.</p>
      </div>
    </div>
  </section>

  <!-- Direkt mit Sabine -->
  <section class="py-16 bg-brand-cream">
    <div class="container-narrow">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="flex-shrink-0">
          <img src={`${import.meta.env.BASE_URL}/sabine-salowsky.webp`} alt="Sabine Salowsky" class="w-28 h-28 rounded-sm object-cover object-top shadow-md" loading="lazy" width="400" height="400" />
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-accent mb-3">So arbeiten wir</p>
          <p class="font-serif text-xl font-semibold text-brand-dark mb-3">Sie arbeiten während des gesamten Audits direkt mit Sabine. Keine Übergaben, keine Junior-Berater.</p>
          <p class="text-slate-600 leading-relaxed">Das Audit wird persönlich von Sabine Salowsky, B.Sc. Ergotherapie, Dipl.-Biol., durchgeführt. Sie analysiert die Arbeitsumgebungen Ihres Teams, verfasst den Bericht, präsentiert die Ergebnisse und steht für Rückfragen zur Verfügung. Für ein KMU ist dieser direkte Zugang zu einer Fachspezialistin wirklich ungewöhnlich — und genau das macht den Unterschied zwischen einem Bericht, der in der Schublade landet, und einem, der tatsächlich umgesetzt wird.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Bereit, das Arbeitsumfeld Ihres Teams zu verstehen?</p>
      <h2 class="font-serif text-3xl font-semibold text-white leading-tight mb-6">
        Wohlbefindens-Analyse für KMU anfragen und das vollständige Bild sehen.
      </h2>
      <a href={`${import.meta.env.BASE_URL}/de/kontakt`} class="btn-primary text-base px-8 py-4">Audit anfragen</a>
    </div>
  </section>

</BaseLayout>
