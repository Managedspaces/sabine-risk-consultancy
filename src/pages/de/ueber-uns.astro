---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Über Sabine Salowsky | Beraterin für betriebliches Wohlbefinden";
const description = "Sabine Salowsky (B.Sc. Ergotherapie, Dipl.-Biol.) ist zweisprachige Beraterin für betriebliches Wohlbefinden für KMU in Deutschland, Österreich, der Schweiz, UK und Irland.";

const siteURL = 'https://sabine-risk-consultancy.netlify.app';

const dePersonSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteURL}/#sabine`,
  "name": "Sabine Salowsky",
  "jobTitle": "Beraterin für betriebliches Wohlbefinden",
  "url": `${siteURL}/de/ueber-uns`,
  "image": `${siteURL}/sabine-salowsky.webp`,
  "knowsLanguage": ["de", "en"],
  "knowsAbout": ["Ergonomie", "Betriebliches Wohlbefinden", "Ergotherapie", "Gefährdungsbeurteilung", "Biophiles Design", "Physiologische Psychologie"],
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "degree", "name": "B.Sc. Ergotherapie", "recognizedBy": { "@type": "Organization", "name": "Fachhochschule Wiener Neustadt" } },
    { "@type": "EducationalOccupationalCredential", "credentialCategory": "degree", "name": "Diplom-Biologin, Physiologische Psychologie", "recognizedBy": { "@type": "Organization", "name": "Eberhard-Karls-Universität Tübingen" } }
  ],
  "worksFor": { "@id": `${siteURL}/#organization` }
};
---

<BaseLayout
  title={title}
  description={description}
  lang="de"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/de/ueber-uns"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/about"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de/ueber-uns"
  breadcrumbs={[{name:'Startseite',url:'/de'},{name:'Über uns',url:'/de/ueber-uns'}]}
  pageSchema={dePersonSchema}
>

  <section class="relative bg-brand-dark py-20 md:py-28 overflow-hidden" style="min-height:380px">
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/hero-about.webp`} alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.90) 0%, rgba(10,36,99,0.75) 60%, rgba(10,36,99,0.55) 100%);"></div>
    </div>
    <div class="container-wide relative">
      <p class="section-label text-brand-accentLight mb-4">Über die Beratung</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-2xl">
        Über Sabine Salowsky
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-2xl">
        Arbeitsschutz- und Ergonomie-Spezialistin. Zweisprachig. Vollständig digital. Konzipiert für KMU, die die Expertise eines grossen Anbieters benötigen, ohne dessen Komplexität und Kosten.
      </p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
        <div>
          <div class="bg-brand-dark rounded-sm aspect-[4/5] relative overflow-hidden mb-6">
            <img src={`${import.meta.env.BASE_URL}/sabine-salowsky.webp`} alt="Sabine Salowsky" class="w-full h-full object-cover" loading="lazy" width="400" height="400" />
            <div class="absolute bottom-6 left-6 right-6">
              <div class="bg-brand-dark/80 backdrop-blur-sm rounded-sm p-4 border border-white/10">
                <p class="font-serif text-white text-lg font-semibold">Sabine Salowsky</p>
                <p class="text-brand-accentLight text-xs mt-1">B.Sc. Ergotherapie, Dipl.-Biol.</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-sm border border-slate-100 p-6 shadow-sm">
            <h3 class="font-serif text-base font-semibold text-brand-dark mb-4">Qualifikationen &amp; Expertise</h3>
            <ul class="space-y-3">
              {[
                "B.Sc. Ergotherapie",
                "Diplom-Biologin (Physiologische Psychologie)",
                "Betriebsmedizinische Erfahrung (D. Swarovski KG)",
                "Forschungshintergrund (Max-Planck-Institut, Tübingen)",
                "Zweisprachig: Deutsch und Englisch auf muttersprachlichem Niveau",
                "Jurisdiktionsübergreifende Compliance: DACH, UK, Irland, Australien",
              ].map(item => (
                <li class="flex items-start gap-3 text-sm text-slate-600">
                  <svg class="w-4 h-4 text-brand-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div>
          <p class="section-label mb-4">Der Ansatz</p>
          <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6 leading-tight">
            Verhältnismässige Expertise. Prüfungsfeste Ergebnisse. Keine generischen Checklisten.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-5">
            Effektive Ergonomie-Beratung erfordert mehr als nur eine Checkliste. Sie erfordert ein tiefes, wissenschaftliches Verständnis der menschlichen Physiologie, Kognition und funktionellen Kapazität.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            Mein Hintergrund basiert auf dieser wissenschaftlichen Genauigkeit. Ich besitze einen <strong>B.Sc. in Ergotherapie</strong> und ein Diplom als <strong>Biologin</strong> mit Schwerpunkt Physiologische Psychologie. Diese Doppelqualifikation bildet die Grundlage für meinen Ansatz: die Bewertung der physischen und kognitiven Anforderungen des Arbeitsplatzes durch eine klinische Brille.
          </p>
          <p class="text-slate-600 leading-relaxed mb-5">
            Vor der Gründung dieser Beratung umfasste meine Karriere die betriebliche Gesundheitsförderung – einschliesslich direkter Erfahrung in der Abteilung Arbeitsmedizin der D. Swarovski KG in Österreich – sowie Forschungstätigkeiten am Max-Planck-Institut für Biologische Kybernetik und am Lehrstuhl für Kognitive Neurowissenschaften der Universität Tübingen. Darüber hinaus habe ich umfangreich in klinischen Einrichtungen in Deutschland und Österreich gearbeitet.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Heute wende ich diese klinische und wissenschaftliche Expertise an, um KMU beim Management ihrer Arbeitsplatzrisiken zu unterstützen. Meine Zweisprachigkeit (Muttersprache Deutsch, fliessend Englisch) und meine jurisdiktionsübergreifende Erfahrung bedeuten, dass Unternehmen mit Mitarbeitern in der DACH-Region, Grossbritannien und Irland mit einer einzigen Spezialistin zusammenarbeiten können, die sowohl die physischen Realitäten der Arbeit als auch die rechtlichen Rahmenbedingungen versteht.
          </p>
          <a href={`${import.meta.env.BASE_URL}/de/kontakt`} class="btn-primary">Beratung anfragen</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center">
        <p class="section-label mb-4">Die Philosophie</p>
        <blockquote class="font-serif text-2xl md:text-3xl font-medium text-brand-dark leading-relaxed mb-8">
          „Ergonomie ist keine Wellness-Initiative. Sie ist eine gesetzliche Pflicht, ein Instrument zur Haftungsminimierung und, wenn sie richtig umgesetzt wird, ein echter Treiber für Produktivität und Mitarbeiterbindung."
        </blockquote>
        <p class="text-slate-600 leading-relaxed">
          Jede von dieser Beratung erstellte Arbeit wird mit einer Frage im Sinn konzipiert: Würde diese Dokumentation den Kunden im Falle einer Betriebsprüfung, eines Versicherungsfalles oder eines Rechtsstreits schützen? Wenn die Antwort nein ist, ist sie nicht fertig.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Mit Sabine zusammenarbeiten</p>
      <h2 class="font-serif text-3xl font-semibold text-white leading-tight mb-6">
        Lassen Sie uns Ihren Compliance-Bedarf besprechen.
      </h2>
      <a href={`${import.meta.env.BASE_URL}/de/kontakt`} class="btn-primary text-base px-8 py-4">Beratung anfragen</a>
    </div>
  </section>

</BaseLayout>
