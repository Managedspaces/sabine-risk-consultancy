---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { TOOLS_APP_URL } from '../../../config/site';

const title = "Gefährdungsbeurteilung erstellen | Tool | Sabine Salowsky";
const description = "Erstellen Sie eine maßgeschneiderte, prüfungssichere Gefährdungsbeurteilung mit der 5×5-Risikomatrix. 9 Gefährdungsarten, Schutzmaßnahmen dokumentieren, PDF-Export.";

const canonicalUrl = "https://sabine-risk-consultancy.netlify.app/de/tools/gefaehrdungsbeurteilung-erstellen";
const hreflangPairs = [
  { lang: "en", url: "https://sabine-risk-consultancy.netlify.app/tools/risk-assessment-builder" },
  { lang: "de", url: "https://sabine-risk-consultancy.netlify.app/de/tools/gefaehrdungsbeurteilung-erstellen" },
  { lang: "x-default", url: "https://sabine-risk-consultancy.netlify.app/tools/risk-assessment-builder" }
];

const breadcrumbs = [
  { name: "Startseite", url: "/de" },
  { name: "Tools", url: "/de/tools" },
  { name: "Gefährdungsbeurteilung erstellen", url: "/de/tools/gefaehrdungsbeurteilung-erstellen" }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Gefährdungsbeurteilung erstellen Tool",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "WebBrowser",
  "description": "Erstellen Sie eine maßgeschneiderte Gefährdungsbeurteilung mit der 5×5-Risikomatrix.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  hreflangPairs={hreflangPairs}
  breadcrumbs={breadcrumbs}
  schema={schema}
  lang="de"
>

  <section class="pt-32 pb-20 bg-brand-dark text-white">
    <div class="container-narrow">
      <a href="/de/tools" class="inline-block text-brand-accentLight hover:text-white transition-colors mb-8">&larr; Zurück zu allen Tools</a>
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="flex-1">
          <p class="section-label text-brand-accentLight mb-4">Professionelles Tool</p>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-tight mb-6">
            Gefährdungsbeurteilung erstellen
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed mb-8">
            Erstellen Sie eine maßgeschneiderte, prüfungssichere Gefährdungsbeurteilung. Wählen Sie Gefährdungsarten, bewerten Sie Eintrittswahrscheinlichkeit und Schwere mit der Standard-5×5-Risikomatrix und dokumentieren Sie Schutzmaßnahmen.
          </p>
          <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-4">Tool starten</a>
        </div>
        <div class="w-full md:w-1/3 bg-white/5 border border-white/10 rounded-sm p-8">
          <h3 class="font-serif text-xl font-semibold mb-4">Tool-Spezifikationen</h3>
          <ul class="space-y-4 text-slate-300">
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Gefährdungsarten</span> <span class="font-semibold text-white">9</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Methodik</span> <span class="font-semibold text-white">5×5-Matrix</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Rechtsrahmen</span> <span class="font-semibold text-white">ArbSchG § 5–6</span>
            </li>
            <li class="flex justify-between pb-2">
              <span>Ausgabe</span> <span class="font-semibold text-white">PDF-Bericht</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6">Ein strukturierter Ansatz für die Gefährdungsbeurteilung</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          Gemäß ArbSchG §§ 5 und 6 ist jeder Arbeitgeber verpflichtet, Gefährdungen zu ermitteln, zu bewerten und geeignete Maßnahmen zu treffen. Die Beurteilung muss schriftlich dokumentiert werden — bei mehr als 10 Beschäftigten ist dies ausnahmslos Pflicht.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed mb-10">
          Dieses Tool ersetzt unstrukturierte Tabellenkalkulationen durch eine rigorose, normengerechte Methodik. Es zwingt den Nutzer, Risiken objektiv zu bewerten — vor und nach der Umsetzung von Schutzmaßnahmen.
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">9 Gefährdungskategorien</h3>
            <p class="text-slate-600">Vorausgefüllte Gefährdungsvorlagen für Stolpern &amp; Stürzen, manuelle Handhabung, Brand, Elektrizität, Gefahrstoffe, Absturzgefahr, psychische Belastung und Bildschirmarbeit — plus benutzerdefinierte Einträge.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">Die 5×5-Risikomatrix</h3>
            <p class="text-slate-600">Bewerten Sie objektiv die Eintrittswahrscheinlichkeit (1–5) und die Schwere (1–5) eines Ereignisses und erhalten Sie eine klare RAG-Risikoeinstufung (Rot, Gelb, Grün).</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">Schutzmaßnahmen &amp; Restrisiko</h3>
            <p class="text-slate-600">Dokumentieren Sie die genauen Maßnahmen zur Risikominderung und berechnen Sie automatisch das neue, niedrigere Restrisiko — entsprechend dem STOP-Prinzip.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">Prüfungssichere Ausgabe</h3>
            <p class="text-slate-600">Erstellt einen sauber formatierten, datierten PDF-Bericht, der direkt in Ihr Compliance-Dokumentationssystem abgelegt werden kann — bereit für Berufsgenossenschaft oder Gewerbeaufsicht.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-cream">
    <div class="container-narrow">
      <div class="bg-white p-10 md:p-16 rounded-sm shadow-sm border border-slate-200 text-center">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-4">Komplexes Arbeitsumfeld?</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8 max-w-2xl mx-auto">
          Bei mehreren Gefährdungsarten in einem wachsenden Unternehmen reicht die Selbstbeurteilung möglicherweise nicht aus, um die Compliance sicherzustellen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">Tool ausprobieren</a>
          <a href="/de/leistungen/arbeitsschutz-audit" class="px-6 py-3 border-2 border-brand-dark text-brand-dark font-semibold rounded-sm hover:bg-brand-dark hover:text-white transition-colors">Professionelles Audit anfragen</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
