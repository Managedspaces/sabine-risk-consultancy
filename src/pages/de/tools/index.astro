---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { TOOLS_APP_URL } from '../../../config/site';

const title = "Arbeitsplatz-Beurteilungstools | Sabine Salowsky";
const description = "Professionelle Selbstbeurteilungstools für Ergonomie, Homeoffice-Sicherheit und psychosoziale Gesundheit. Entwickelt von einer Fachspezialistin, konzipiert für KMU.";

const canonicalUrl = "https://sabine-risk-consultancy.netlify.app/de/tools";
const hreflangPairs = [
  { lang: "en", url: "https://sabine-risk-consultancy.netlify.app/tools" },
  { lang: "de", url: "https://sabine-risk-consultancy.netlify.app/de/tools" },
  { lang: "x-default", url: "https://sabine-risk-consultancy.netlify.app/tools" }
];

const breadcrumbs = [
  { name: "Startseite", url: "/de" },
  { name: "Tools", url: "/de/tools" }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Arbeitsplatz-Beurteilungstools",
  "description": "Eine Sammlung professioneller Selbstbeurteilungstools für Ergonomie und betriebliches Wohlbefinden.",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "url": "https://sabine-risk-consultancy.netlify.app/de/tools/ergonomische-gefaehrdungsbeurteilung" },
    { "@type": "ListItem", "position": 2, "url": "https://sabine-risk-consultancy.netlify.app/de/tools/homeoffice-beurteilung" },
    { "@type": "ListItem", "position": 3, "url": "https://sabine-risk-consultancy.netlify.app/de/tools/psychosoziale-gefaehrdungsbeurteilung" },
    { "@type": "ListItem", "position": 4, "url": "https://sabine-risk-consultancy.netlify.app/de/tools/gefaehrdungsbeurteilung-erstellen" }
  ]
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  hreflangPairs={hreflangPairs}
  breadcrumbs={breadcrumbs}
  schema={schema}
  lang="de"
>

  <!-- Hero -->
  <section class="pt-32 pb-20 bg-brand-dark text-white">
    <div class="container-narrow">
      <p class="section-label text-brand-accentLight mb-4">Professionelle Beurteilungstools</p>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold leading-tight mb-6">
        Ihren Arbeitsplatz verstehen.<br/>
        <span class="text-brand-accent">Die Realität erkennen.</span>
      </h1>
      <p class="text-xl text-slate-300 leading-relaxed mb-10 max-w-2xl">
        Wir haben unsere Fachmethodik in eine Reihe professioneller Selbstbeurteilungstools übertragen. Nutzen Sie diese, um den aktuellen Stand Ihres Teams zu erfassen, unmittelbare Risiken zu identifizieren und rechtssichere Dokumentation zu erstellen.
      </p>
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="py-20 bg-brand-cream">
    <div class="container-narrow">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Tool 1 -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">29 Fragen · 6 Kategorien</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Ergonomische Gefährdungsbeurteilung</h2>
            <p class="text-slate-600 leading-relaxed">
              Bewerten Sie die Ergonomie Ihres Büroarbeitsplatzes in sechs Dimensionen der körperlichen Gesundheit — von Haltung und Ausstattung bis hin zu Umgebungsfaktoren.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/de/tools/ergonomische-gefaehrdungsbeurteilung`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Mehr erfahren &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Tool starten &#8599;</a>
          </div>
        </div>

        <!-- Tool 2 -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">30 Fragen · 6 Kategorien</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Homeoffice-Beurteilung</h2>
            <p class="text-slate-600 leading-relaxed">
              Beurteilen Sie die Sicherheit und Eignung von Heimarbeitsplätzen — von elektrischer Sicherheit und Brandschutz bis hin zu Ergonomie und Arbeitsorganisation.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/de/tools/homeoffice-beurteilung`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Mehr erfahren &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Tool starten &#8599;</a>
          </div>
        </div>

        <!-- Tool 3 -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">20 Fragen · 5 Kategorien</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Psychosoziale Gefährdungsbeurteilung</h2>
            <p class="text-slate-600 leading-relaxed">
              Messen Sie Stress, Arbeitsbelastung, Rollenklarheit und Work-Life-Balance. Erstellt Berichte gemäß ISO 45003 und der DGUV-Empfehlung.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/de/tools/psychosoziale-gefaehrdungsbeurteilung`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Mehr erfahren &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Tool starten &#8599;</a>
          </div>
        </div>

        <!-- Tool 4 -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">9 Gefährdungsarten · 5×5-Matrix</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Gefährdungsbeurteilung erstellen</h2>
            <p class="text-slate-600 leading-relaxed">
              Erstellen Sie eine maßgeschneiderte, prüfungssichere Gefährdungsbeurteilung mit der Standard-5×5-Risikomatrix und dokumentieren Sie Schutzmaßnahmen.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/de/tools/gefaehrdungsbeurteilung-erstellen`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Mehr erfahren &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Tool starten &#8599;</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Methodology Note -->
  <section class="py-20 bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6">Klinisch fundiert. Nicht nur Checklisten.</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          Diese Tools wurden von Sabine Salowsky entwickelt — auf Basis ihres Hintergrunds in Ergotherapie (B.Sc.) und Physiologischer Psychologie (Dipl.-Biol.). Sie fragen nicht nur, ob der Monitor auf der richtigen Höhe steht, sondern bewerten das gesamte Arbeitsumfeld, um die Ursachen von Erschöpfung und Produktivitätsverlust zu identifizieren.
        </p>
        <a href={`${import.meta.env.BASE_URL}/de/ueber-uns`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Mehr über unsere Methodik &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>
