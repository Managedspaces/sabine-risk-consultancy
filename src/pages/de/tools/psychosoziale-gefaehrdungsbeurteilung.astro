---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { TOOLS_APP_URL } from '../../../config/site';

const title = "Psychosoziale Gefährdungsbeurteilung Tool | Sabine Salowsky";
const description = "Messen Sie Stress, Arbeitsbelastung, Rollenklarheit und Work-Life-Balance. Erstellt Berichte gemäß ISO 45003 und der DGUV-Empfehlung 114-002.";

const canonicalUrl = "https://sabine-risk-consultancy.netlify.app/de/tools/psychosoziale-gefaehrdungsbeurteilung";
const hreflangPairs = [
  { lang: "en", url: "https://sabine-risk-consultancy.netlify.app/tools/psychosocial-risk-assessment" },
  { lang: "de", url: "https://sabine-risk-consultancy.netlify.app/de/tools/psychosoziale-gefaehrdungsbeurteilung" },
  { lang: "x-default", url: "https://sabine-risk-consultancy.netlify.app/tools/psychosocial-risk-assessment" }
];

const breadcrumbs = [
  { name: "Startseite", url: "/de" },
  { name: "Tools", url: "/de/tools" },
  { name: "Psychosoziale Gefährdungsbeurteilung", url: "/de/tools/psychosoziale-gefaehrdungsbeurteilung" }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Psychosoziale Gefährdungsbeurteilung Tool",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "WebBrowser",
  "description": "Messen Sie Stress, Arbeitsbelastung und Work-Life-Balance gemäß ISO 45003.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  hreflangPairs={hreflangPairs}
  breadcrumbs={breadcrumbs}
  schema={schema}
  lang="de"
>

  <section class="pt-32 pb-20 bg-brand-dark text-white">
    <div class="container-narrow">
      <a href="/de/tools" class="inline-block text-brand-accentLight hover:text-white transition-colors mb-8">&larr; Zurück zu allen Tools</a>
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="flex-1">
          <p class="section-label text-brand-accentLight mb-4">Selbstbeurteilungstool</p>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-tight mb-6">
            Psychosoziale Gefährdungsbeurteilung
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed mb-8">
            Messen Sie Stress, Arbeitsbelastung, Rollenklarheit und Work-Life-Balance. Ein 20-Fragen-Tool, das einen vertraulichen Mitarbeiterbericht und einen rechtssicheren Arbeitgeberbericht gemäß ISO 45003 und DGUV-Empfehlung 114-002 erstellt.
          </p>
          <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-4">Beurteilung starten</a>
        </div>
        <div class="w-full md:w-1/3 bg-white/5 border border-white/10 rounded-sm p-8">
          <h3 class="font-serif text-xl font-semibold mb-4">Tool-Spezifikationen</h3>
          <ul class="space-y-4 text-slate-300">
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Fragen</span> <span class="font-semibold text-white">20</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Kategorien</span> <span class="font-semibold text-white">5</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Norm</span> <span class="font-semibold text-white">ISO 45003</span>
            </li>
            <li class="flex justify-between pb-2">
              <span>Zeitaufwand</span> <span class="font-semibold text-white">5 Min.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6">Die verborgenen Ursachen von Burnout</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          Psychosoziale Gefährdungen sind Aspekte der Arbeitsgestaltung und -organisation, die das Risiko von arbeitsbedingtem Stress erhöhen. Seit der Novellierung des ArbSchG im Jahr 2013 ist die Beurteilung psychischer Belastungen ausdrücklich in die Gefährdungsbeurteilung einzubeziehen.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed mb-10">
          Für Remote- und Hybrid-Teams ist diese Beurteilung besonders relevant: Isolation, verschwimmende Grenzen zwischen Arbeit und Privatleben und fehlende soziale Unterstützung sind die häufigsten Treiber von Burnout in verteilten Teams.
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">1. Arbeitsbelastung &amp; Fristen</h3>
            <p class="text-slate-600">Misst die Nachhaltigkeit des Aufgabenvolumens, Zeitdruck und kognitive Anforderungen.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">2. Rollenklarheit &amp; Unterstützung</h3>
            <p class="text-slate-600">Bewertet, ob Erwartungen klar sind und ob der Mitarbeiter über die notwendigen Ressourcen und Führungsunterstützung verfügt.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">3. Arbeitsumgebung &amp; Unternehmenskultur</h3>
            <p class="text-slate-600">Bewertet psychologische Sicherheit, Teamdynamik und das Vorhandensein von zwischenmenschlichen Spannungen oder Isolation.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">4. Work-Life-Balance</h3>
            <p class="text-slate-600">Prüft die Möglichkeit zur Abgrenzung, Grenzmanagement im Homeoffice und Erholungszeiten.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">5. Mitarbeiterwohlbefinden</h3>
            <p class="text-slate-600">Ein Basiswert für aktuelles Energieniveau, Schlafqualität und allgemeine Arbeitsgesundheit.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-cream">
    <div class="container-narrow">
      <div class="bg-white p-10 md:p-16 rounded-sm shadow-sm border border-slate-200 text-center">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-4">Wie handeln Sie auf Basis der Daten?</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8 max-w-2xl mx-auto">
          Psychosoziale Gefährdungen zu identifizieren ist nur der erste Schritt. Wenn Ihr Team Anzeichen von Burnout zeigt, brauchen Sie einen strukturierten Maßnahmenplan, der die Ursachen adressiert.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">Tool ausprobieren</a>
          <a href="/de/kontakt" class="px-6 py-3 border-2 border-brand-dark text-brand-dark font-semibold rounded-sm hover:bg-brand-dark hover:text-white transition-colors">Mit Sabine sprechen</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
