---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Book a Consultation | Sabine Salowsky Workplace Wellbeing";
const description = "Book a free 20-minute conversation to discuss your team's wellbeing needs. Remote delivery across DACH, UK and Ireland. No obligation.";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/contact"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/contact"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de/kontakt"
  breadcrumbs={[{name:'Home',url:'/'},{name:'Contact',url:'/contact'}]}
>

  <!-- Page Header -->
  <section class="relative bg-brand-dark py-20 md:py-24 overflow-hidden" style="min-height:360px">
    <div class="absolute inset-0">
      <img src="/images/hero-contact.webp" alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.90) 0%, rgba(10,36,99,0.75) 60%, rgba(10,36,99,0.55) 100%);"></div>
    </div>
    <div class="container-wide relative">
      <p class="section-label text-brand-accentLight mb-4">Get in Touch</p>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-6 max-w-xl">
        Let us discuss your compliance requirements.
      </h1>
      <p class="text-slate-300 text-lg leading-relaxed max-w-xl">
        Book a free 20-minute consultation to discuss your remote workforce risk profile and the most appropriate service for your business.
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="py-20 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">

        <!-- Form -->
        <div class="bg-white rounded-sm border border-slate-100 p-8 shadow-sm">
          <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-6">Send an Enquiry</h2>
          <form name="contact" method="POST" action="/contact/success" class="space-y-5">
            <input type="hidden" name="form-name" value="contact" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">First Name *</label>
                <input type="text" id="first-name" name="first-name" required class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors" placeholder="Your first name" />
              </div>
              <div>
                <label for="last-name" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Last Name *</label>
                <input type="text" id="last-name" name="last-name" required class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors" placeholder="Your last name" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Work Email *</label>
              <input type="email" id="email" name="email" required class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors" placeholder="you@company.com" />
            </div>
            <div>
              <label for="company" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Company Name</label>
              <input type="text" id="company" name="company" class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors" placeholder="Your company name" />
            </div>
            <div>
              <label for="team-size" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Approximate Team Size</label>
              <select id="team-size" name="team-size" class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors bg-white">
                <option value="">Select team size</option>
                <option value="1-20">1 to 20 employees</option>
                <option value="21-50">21 to 50 employees</option>
                <option value="51-100">51 to 100 employees</option>
                <option value="101-150">101 to 150 employees</option>
                <option value="150+">More than 150 employees</option>
              </select>
            </div>
            <div>
              <label for="jurisdiction" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Primary Jurisdiction</label>
              <select id="jurisdiction" name="jurisdiction" class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors bg-white">
                <option value="">Select jurisdiction</option>
                <option value="uk">United Kingdom</option>
                <option value="ireland">Ireland</option>
                <option value="germany">Germany</option>
                <option value="austria">Austria</option>
                <option value="switzerland">Switzerland</option>
                <option value="australia">Australia</option>
                <option value="multiple">Multiple jurisdictions</option>
              </select>
            </div>
            <div>
              <label for="service" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Service of Interest</label>
              <select id="service" name="service" class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors bg-white">
                <option value="">Select a service</option>
                <option value="remote-assessment">Remote Ergonomic Assessment</option>
                <option value="risk-audit">SME Workplace Risk Audit</option>
                <option value="retainer">Workplace Risk Retainer</option>
                <option value="unsure">Not sure yet</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-xs font-semibold text-slate-600 uppercase tracking-wide mb-1.5">Your Message</label>
              <textarea id="message" name="message" rows="4" class="w-full border border-slate-200 rounded-sm px-4 py-2.5 text-sm text-brand-dark focus:outline-none focus:border-brand-accent transition-colors resize-none" placeholder="Tell us briefly about your situation and what you are looking to achieve."></textarea>
            </div>
            <button type="submit" class="btn-primary w-full text-center py-3">Send Enquiry</button>
            <p class="text-xs text-slate-400 text-center">We respond to all enquiries within one working day.</p>
          </form>
        </div>

        <!-- Info Panel -->
        <div class="space-y-8">
          <div>
            <p class="section-label mb-4">What to Expect</p>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-5">A straightforward process from first contact to delivery.</h2>
            <div class="space-y-5">
              {[
                ["1. Initial Response", "We respond to all enquiries within one working day. If you have requested a consultation, we will propose two or three time slots for a 20-minute video call."],
                ["2. Discovery Call", "A focused 20-minute call to understand your workforce profile, regulatory context, and compliance priorities. No obligation, no sales pressure."],
                ["3. Proposal", "Following the call, we send a clear written proposal confirming the scope, deliverables, timeline, and fixed fee. No surprises."],
                ["4. Engagement", "On acceptance, we begin work immediately. Most engagements are completed and delivered within ten working days."],
              ].map(([title, desc]) => (
                <div class="flex gap-4">
                  <div class="w-7 h-7 bg-brand-accent text-white text-xs font-semibold rounded-sm flex items-center justify-center flex-shrink-0 mt-0.5">{title.charAt(0)}</div>
                  <div>
                    <p class="font-semibold text-brand-dark text-sm mb-1">{title.substring(3)}</p>
                    <p class="text-slate-600 text-sm leading-relaxed">{desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-brand-dark rounded-sm p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-accentLight mb-4">Response Commitment</p>
            <p class="text-slate-300 text-sm leading-relaxed mb-4">
              All enquiries receive a personal response within one working day. We do not use automated responses or chatbots. You will hear from Sabine directly.
            </p>
            <p class="text-slate-400 text-xs">
              Working hours: Monday to Friday, 09:00 to 17:00 CET. Enquiries received outside these hours are responded to on the next working day.
            </p>
          </div>

          <div class="bg-white rounded-sm border border-slate-100 p-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-accent mb-3">Languages</p>
            <p class="text-sm text-slate-600">Enquiries and consultations are available in English and German. Please feel free to write in either language.</p>
            <p class="text-xs text-slate-400 mt-2 italic">Anfragen und Beratungen sind auf Englisch und Deutsch möglich.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
