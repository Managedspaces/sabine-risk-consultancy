---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Remote Workplace Wellbeing Advisory for SMEs | Sabine Salowsky";
const description = "Practical workplace wellbeing for remote and hybrid SMEs of 10–250 people. Ergonomic assessments, wellbeing audits and ongoing advisory across DACH, UK and Ireland — delivered directly by Sabine Salowsky, B.Sc. Ergotherapie.";

const siteURL = 'https://sabine-risk-consultancy.netlify.app';

const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteURL}/#webpage`,
  "url": siteURL,
  "name": title,
  "description": description,
  "inLanguage": "en-GB",
  "isPartOf": { "@id": `${siteURL}/#website` },
  "about": { "@id": `${siteURL}/#organization` },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL }]
  }
};
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  canonicalURL="https://sabine-risk-consultancy.netlify.app/"
  hreflangEn="https://sabine-risk-consultancy.netlify.app/"
  hreflangDe="https://sabine-risk-consultancy.netlify.app/de"
  pageSchema={homepageSchema}
>

  <!-- Hero Section -->
  <section class="relative bg-brand-dark overflow-hidden" style="min-height:600px">
    <!-- Full-bleed hero image with navy overlay -->
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/hero-homepage.webp`} alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" loading="eager" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.88) 0%, rgba(10,36,99,0.72) 50%, rgba(10,36,99,0.55) 100%);"></div>
    </div>
    <div class="container-wide relative py-28 md:py-36">
      <div class="max-w-3xl">
        <p class="section-label text-brand-accentLight mb-6">Remote &amp; Hybrid Workplace Wellbeing Advisory</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-white leading-tight mb-6">
          Healthy Company.<br />
          Healthy People.<br />
          <span class="text-brand-accentLight">Healthy Teams.</span>
        </h1>
        <p class="text-slate-300 text-lg md:text-xl leading-relaxed mb-6 max-w-2xl">
          You do not need a global health and safety department. You need practical, evidence-based systems that actually work for your business — delivered by one specialist who works directly with you.
        </p>
        <p class="text-slate-400 text-base leading-relaxed mb-10 max-w-2xl">
          Sabine Salowsky works with SMEs across Germany, Switzerland, Austria, the UK, and Ireland — helping companies build working environments where people genuinely flourish, and where the business results follow.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/services" class="btn-primary">View Our Services</a>
          <a href="/contact" class="inline-block border border-slate-400 text-slate-300 font-semibold px-6 py-3 rounded-sm tracking-wide text-sm uppercase transition-all duration-200 hover:bg-white hover:text-brand-dark">Book a Conversation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-white border-b border-slate-100">
    <div class="container-wide py-6">
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-xs font-semibold text-slate-500 uppercase tracking-widest">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          You work directly with Sabine
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          SME Specialist
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          🇪🇺 EU &amp; Cross-border Advisory
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          EU-OSHA Aligned
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Bilingual EN / DE
        </span>
      </div>
    </div>
  </section>

  <!-- Wellbeing & Productivity — LEAD SECTION -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background-color:#0A2463">
    <!-- Subtle biophilic background image -->
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/wellbeing-bg.webp`} alt="" role="presentation" class="w-full h-full object-cover opacity-15" />
    </div>
    <div class="container-wide">
      <div class="relative text-center max-w-2xl mx-auto mb-16">
        <p class="section-label text-brand-accentLight mb-4">The Wellbeing Advantage</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-white leading-tight mb-6">
          The whole environment matters.<br />
          <span class="text-brand-accentLight">Not just the workstation.</span>
        </h2>
        <p class="text-slate-300 leading-relaxed">
          The science of workplace wellbeing has moved well beyond desk height and monitor position. The physical environment, the sensory environment, access to restorative spaces, the quality of light, even the typography on a screen — all of it shapes how your people think, feel, and perform. And the evidence connecting that environment to business outcomes is now unambiguous.
        </p>
      </div>

      <!-- Two-column: narrative + stat grid -->
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-16 items-start mb-16">
        <div>
          <h3 class="font-serif text-2xl font-semibold text-white mb-5">The performance you are leaving on the table.</h3>
          <p class="text-slate-300 leading-relaxed mb-5">
            A University of Oxford study found that happy workers are 13% more productive. A global study of 7,600 employees found that those with natural elements and green views in their workspace were 6% more productive and reported 15% higher levels of wellbeing. Circadian-aligned lighting measurably reduces afternoon fatigue and restores alertness. Even the fonts and spacing on a screen affect cognitive load and how quickly people tire.
          </p>
          <p class="text-slate-300 leading-relaxed mb-5">
            None of this is abstract. It is the accumulated effect of dozens of small environmental decisions — most of which remote and hybrid workers make without any guidance. A home workstation is rarely designed. It is assembled from whatever is available. And the cumulative cost of that improvisation, in energy, focus, and output, is significant.
          </p>
          <p class="text-slate-300 leading-relaxed mb-8">
            In Germany alone, musculoskeletal disorders cost businesses over €17 billion annually in lost productivity. But the physical discomfort is only part of the picture. Add the cognitive drag of poor lighting, the mental fatigue of a cluttered sensory environment, and the absence of any restorative space, and the true cost of a poorly designed work environment is considerably higher.
          </p>
          <div class="border-l-4 pl-5" style="border-color:#C65A1E">
            <p class="text-white font-medium leading-relaxed">
              Research from UC Berkeley's Center for Occupational and Environmental Health found that workplace safety and ergonomics initiatives are associated with an average 66% increase in productivity and a benefit-to-cost ratio of between 2:1 and 10:1. Every euro invested returns between two and ten euros in measurable business benefit.
            </p>
            <p class="text-slate-400 text-xs mt-3">Source: UC Berkeley Center for Occupational and Environmental Health, 2021</p>
          </div>
        </div>

        <!-- Stat cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="bg-brand-accent/20 border border-brand-accent/30 rounded-sm p-6">
            <p class="font-serif text-4xl font-semibold text-brand-accentLight mb-3">€17bn+</p>
            <p class="text-slate-300 text-sm leading-snug mb-2">Lost annually in Germany alone from MSD-related productivity loss — the single largest occupational health cost in the DACH region.</p>
            <p class="text-slate-500 text-xs">Source: EU-OSHA / EFORT White Book</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-sm p-6">
            <p class="font-serif text-4xl font-semibold text-brand-accentLight mb-3">~20%</p>
            <p class="text-slate-300 text-sm leading-snug mb-2">Of all sick days in Germany are caused by musculoskeletal disorders — the leading single cause of workplace absence across the DACH region.</p>
            <p class="text-slate-500 text-xs">Source: AOK Fehlzeiten-Report, 2025</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-sm p-6">
            <p class="font-serif text-4xl font-semibold text-brand-accentLight mb-3">60%</p>
            <p class="text-slate-300 text-sm leading-snug mb-2">Of workers across Europe report one or more musculoskeletal disorders in any 12-month period. Most continue working — but below their true capacity.</p>
            <p class="text-slate-500 text-xs">Source: EU-OSHA / PMC, 2025</p>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-sm p-6">
            <p class="font-serif text-4xl font-semibold text-brand-accentLight mb-3">2–10×</p>
            <p class="text-slate-300 text-sm leading-snug mb-2">Return on investment from ergonomic interventions. For every euro invested in a structured programme, businesses recover between €2 and €10 in measurable benefit.</p>
            <p class="text-slate-500 text-xs">Source: UC Berkeley COEH, 2021</p>
          </div>
        </div>
      </div>

      <!-- Three-column benefit summary -->
      <div class="relative border-t border-white/10 pt-12">
        <p class="text-center text-xs font-semibold uppercase tracking-widest text-slate-500 mb-10">What a holistic wellbeing programme delivers</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-12 h-12 bg-brand-accent/20 rounded-sm flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-brand-accentLight" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>
            </div>
            <h3 class="font-serif text-lg font-semibold text-white mb-2">Sharper Focus, Better Output</h3>
            <p class="text-slate-400 text-sm leading-relaxed">When the physical environment supports the body and the sensory environment supports the mind, people think more clearly, tire more slowly, and produce higher-quality work. The Oxford research puts the productivity uplift at 13%.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-brand-accent/20 rounded-sm flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-brand-accentLight" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
            </div>
            <h3 class="font-serif text-lg font-semibold text-white mb-2">Genuine Happiness at Work</h3>
            <p class="text-slate-400 text-sm leading-relaxed">Access to natural light, green views, restorative spaces, and a thoughtfully designed environment improves mood, reduces stress, and raises wellbeing scores. Employees who feel cared for are more engaged, more loyal, and more likely to stay.</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 bg-brand-accent/20 rounded-sm flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-brand-accentLight" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
            </div>
            <h3 class="font-serif text-lg font-semibold text-white mb-2">Measurable Business Returns</h3>
            <p class="text-slate-400 text-sm leading-relaxed">Gallup research links high employee engagement to 21% higher profitability. UC Berkeley found a 2 to 10 times return on investment from structured workplace wellbeing programmes. Happier people are not just a moral good — they are a commercial one.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="section-label mb-4">Our Services</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brand-dark leading-tight mb-4">
          Practical Wellbeing, Built for SMEs
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Three focused services designed to improve your team's working environment in every dimension — physical, sensory, and psychological — so your people can do their best work every day.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group border border-slate-100 rounded-sm p-8 hover:border-brand-accent hover:shadow-md transition-all duration-200 bg-white">
          <div class="w-10 h-10 bg-brand-cream rounded-sm flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.955 11.955 0 01.75 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-2.376-.694-4.59-1.893-6.455"/></svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-3">Remote Ergonomic Assessment</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">A personalised assessment for remote and hybrid employees. We review their workspace, identify what is holding them back physically, and provide a clear, practical improvement plan — so they feel better and work better.</p>
          <p class="text-xs font-semibold text-brand-accent uppercase tracking-wide mb-6">From €295 per employee</p>
          <a href="/services/remote-ergonomic-assessment" class="text-sm font-semibold text-brand-dark group-hover:text-brand-accent transition-colors flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="group border border-brand-accent rounded-sm p-8 hover:shadow-md transition-all duration-200 bg-white relative">
          <div class="absolute top-4 right-4 bg-brand-accent text-white text-xs font-semibold px-2 py-1 rounded-sm uppercase tracking-wide">Most Popular</div>
          <div class="w-10 h-10 bg-brand-cream rounded-sm flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-3">SME Workplace Wellbeing Audit</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">A comprehensive review of how your remote or hybrid team actually works — covering physical environment, sensory conditions, and working patterns. You receive a clear picture of where your team is losing energy and focus, and a prioritised plan to change it.</p>
          <p class="text-xs font-semibold text-brand-accent uppercase tracking-wide mb-6">Project-based from €1,800</p>
          <a href="/services/sme-risk-audit" class="text-sm font-semibold text-brand-dark group-hover:text-brand-accent transition-colors flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="group border border-slate-100 rounded-sm p-8 hover:border-brand-accent hover:shadow-md transition-all duration-200 bg-white">
          <div class="w-10 h-10 bg-brand-cream rounded-sm flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-3">Ongoing Wellbeing Partnership</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">Continuous wellbeing support as your team grows and changes. Quarterly check-ins, onboarding assessments for new hires, and a direct line to expert guidance — so your team's environment always supports their best performance.</p>
          <p class="text-xs font-semibold text-brand-accent uppercase tracking-wide mb-6">From €550 per month</p>
          <a href="/services/workplace-risk-retainer" class="text-sm font-semibold text-brand-dark group-hover:text-brand-accent transition-colors flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Who We Work With -->
  <section class="py-16 md:py-20" style="background-color:#F5EFE6">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="section-label mb-4">Who We Work With</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brand-dark leading-tight mb-4">
          Built for businesses that take their people seriously.
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Sabine works with SMEs where leadership understands that a healthy, well-supported team is a competitive advantage — and where the working environment is seen as a direct reflection of that commitment.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="bg-white rounded-sm p-6 border border-brand-border shadow-sm">
          <div class="w-10 h-10 bg-brand-accent/10 rounded-sm flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">Remote &amp; Hybrid Businesses</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Companies where some or all of the team works away from a central office — and where the working environment deserves the same attention as any other business asset.</p>
        </div>
        <div class="bg-white rounded-sm p-6 border border-brand-border shadow-sm">
          <div class="w-10 h-10 bg-brand-accent/10 rounded-sm flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">Growing SMEs</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Businesses that have reached the point where a structured, proportionate approach to workplace wellbeing makes clear commercial sense — and where leadership wants to get it right.</p>
        </div>
        <div class="bg-white rounded-sm p-6 border border-brand-border shadow-sm">
          <div class="w-10 h-10 bg-brand-accent/10 rounded-sm flex items-center justify-center mb-4">
