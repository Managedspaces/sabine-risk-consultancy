---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Workplace Risk & Ergonomics Consultancy for Remote-First SMEs | Sabine";
const description = "Defensible ergonomic risk assessments, SME workplace audits, and ongoing compliance retainers for remote and hybrid teams. Serving UK, Ireland, DACH, and Australia.";
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  hreflangEn="https://example.com/"
  hreflangDe="https://example.com/de"
>

  <!-- Hero Section -->
  <section class="relative bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,0.03) 60px, rgba(255,255,255,0.03) 61px), repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,0.03) 60px, rgba(255,255,255,0.03) 61px);"></div>
    </div>
    <div class="container-wide relative py-24 md:py-32">
      <div class="max-w-3xl">
        <p class="section-label text-brand-accentLight mb-6">Workplace Risk &amp; Ergonomics Consultancy</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-white leading-tight mb-8">
          Protect Your Business.<br />
          <span class="text-brand-accentLight">Protect Your People.</span>
        </h1>
        <p class="text-slate-300 text-lg md:text-xl leading-relaxed mb-10 max-w-2xl">
          Defensible ergonomic risk assessments and audit-ready compliance frameworks for remote-first SMEs. We reduce your legal exposure and absenteeism costs without the overhead of enterprise occupational health.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/services" class="btn-primary">View Our Services</a>
          <a href="/contact" class="inline-block border border-slate-400 text-slate-300 font-semibold px-6 py-3 rounded-sm tracking-wide text-sm uppercase transition-all duration-200 hover:bg-white hover:text-brand-dark">Book a Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="bg-white border-b border-slate-100">
    <div class="container-wide py-6">
      <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-xs font-semibold text-slate-500 uppercase tracking-widest">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          HSE Aligned (UK)
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          HSA Compliant (Ireland)
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          ArbSchG / ArbStattV (Germany)
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Safe Work Australia
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-brand-accent" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          Bilingual EN / DE
        </span>
      </div>
    </div>
  </section>

  <!-- Risk Framing -->
  <section class="py-20 md:py-28 bg-brand-bg">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <p class="section-label mb-4">The Risk Reality</p>
          <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brand-dark leading-tight mb-6">
            Ergonomics is no longer just about comfort. It is a compliance obligation.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-6">
            In the UK, employers carry the same legal duty of care for remote workers as for those in the office. The Health and Safety (Display Screen Equipment) Regulations require documented risk assessments for every employee using screens regularly. Failure to comply exposes your business to enforcement action, civil claims, and reputational damage.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            In Germany, the Arbeitsschutzgesetz (ArbSchG) mandates a Gefährdungsbeurteilung for every workplace, including home offices. The obligations are clear. The documentation trail required to defend against a claim is specific. Most SMEs have neither.
          </p>
          <a href="/services" class="btn-primary">Explore Our Services</a>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white rounded-sm p-6 border border-slate-100 shadow-sm">
            <p class="font-serif text-3xl font-semibold text-brand-accent mb-2">511k</p>
            <p class="text-sm text-slate-600 leading-snug">UK workers suffering from work-related musculoskeletal disorders in 2024/25</p>
          </div>
          <div class="bg-white rounded-sm p-6 border border-slate-100 shadow-sm">
            <p class="font-serif text-3xl font-semibold text-brand-accent mb-2">£3,029</p>
            <p class="text-sm text-slate-600 leading-snug">Estimated annual cost of employee absenteeism per person in the UK</p>
          </div>
          <div class="bg-white rounded-sm p-6 border border-slate-100 shadow-sm">
            <p class="font-serif text-3xl font-semibold text-brand-accent mb-2">7.8m</p>
            <p class="text-sm text-slate-600 leading-snug">Working days lost to musculoskeletal disorders in the UK in 2023/24</p>
          </div>
          <div class="bg-brand-dark rounded-sm p-6">
            <p class="font-serif text-3xl font-semibold text-brand-accentLight mb-2">1.8</p>
            <p class="text-sm text-slate-300 leading-snug">Average days per week UK employees work from home, the highest in Europe</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Services -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="section-label mb-4">Our Services</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brand-dark leading-tight mb-4">
          Structured Risk Management, Built for SMEs
        </h2>
        <p class="text-slate-600 leading-relaxed">
          Three focused services designed to take you from compliance risk to documented, defensible protection without the complexity or cost of enterprise occupational health.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group border border-slate-100 rounded-sm p-8 hover:border-brand-accent hover:shadow-md transition-all duration-200 bg-white">
          <div class="w-10 h-10 bg-brand-cream rounded-sm flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.955 11.955 0 01.75 12c0 6.627 5.373 12 12 12s12-5.373 12-12c0-2.376-.694-4.59-1.893-6.455"/></svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-3">Remote Ergonomic Assessment</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">Individual assessment for remote and hybrid employees. Includes questionnaire, photo review, written risk report, and audit-ready documentation aligned with DSE and HSE requirements.</p>
          <p class="text-xs font-semibold text-brand-accent uppercase tracking-wide mb-6">From £295 per employee</p>
          <a href="/services/remote-ergonomic-assessment" class="text-sm font-semibold text-brand-dark group-hover:text-brand-accent transition-colors flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="group border border-brand-accent rounded-sm p-8 hover:shadow-md transition-all duration-200 bg-white relative">
          <div class="absolute top-4 right-4 bg-brand-accent text-white text-xs font-semibold px-2 py-1 rounded-sm uppercase tracking-wide">Most Popular</div>
          <div class="w-10 h-10 bg-brand-cream rounded-sm flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-3">SME Workplace Risk Audit</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">A comprehensive compliance review for your remote or hybrid workforce. Covers policy analysis, risk matrix, executive summary, and a prioritised action plan suitable for HR, legal, and insurance purposes.</p>
          <p class="text-xs font-semibold text-brand-accent uppercase tracking-wide mb-6">Project-based from £1,800</p>
          <a href="/services/sme-risk-audit" class="text-sm font-semibold text-brand-dark group-hover:text-brand-accent transition-colors flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="group border border-slate-100 rounded-sm p-8 hover:border-brand-accent hover:shadow-md transition-all duration-200 bg-white">
          <div class="w-10 h-10 bg-brand-cream rounded-sm flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
          </div>
          <h3 class="font-serif text-xl font-semibold text-brand-dark mb-3">Workplace Risk Retainer</h3>
          <p class="text-slate-600 text-sm leading-relaxed mb-6">Ongoing advisory for SMEs that need continuous compliance support. Includes quarterly reviews, new hire assessments, policy updates, and priority access to expert guidance as your team evolves.</p>
          <p class="text-xs font-semibold text-brand-accent uppercase tracking-wide mb-6">From £550 per month</p>
          <a href="/services/workplace-risk-retainer" class="text-sm font-semibold text-brand-dark group-hover:text-brand-accent transition-colors flex items-center gap-2">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- About Founder -->
  <section class="py-20 md:py-28 bg-brand-cream">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div class="order-2 md:order-1">
          <p class="section-label mb-4">About the Consultancy</p>
          <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brand-dark leading-tight mb-6">
            The rigour of enterprise occupational health. The agility of a boutique specialist.
          </h2>
          <p class="text-slate-600 leading-relaxed mb-6">
            Sabine is a bilingual workplace risk and ergonomics specialist with deep expertise in UK, Irish, and German compliance frameworks. Working exclusively with SMEs of 20 to 150 employees, the consultancy delivers proportionate, evidence-based interventions that stand up to scrutiny.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Every assessment and audit is designed to produce documentation that is defensible, audit-ready, and genuinely useful, not a generic checklist that sits in a drawer.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="text-xs font-semibold bg-white border border-slate-200 text-slate-600 px-3 py-1.5 rounded-sm uppercase tracking-wide">CIEHF Expertise</span>
            <span class="text-xs font-semibold bg-white border border-slate-200 text-slate-600 px-3 py-1.5 rounded-sm uppercase tracking-wide">Bilingual EN / DE</span>
            <span class="text-xs font-semibold bg-white border border-slate-200 text-slate-600 px-3 py-1.5 rounded-sm uppercase tracking-wide">Remote-First</span>
            <span class="text-xs font-semibold bg-white border border-slate-200 text-slate-600 px-3 py-1.5 rounded-sm uppercase tracking-wide">SME Specialist</span>
          </div>
          <a href="/about" class="btn-outline">About Sabine</a>
        </div>
        <div class="order-1 md:order-2">
          <div class="bg-brand-dark rounded-sm aspect-[4/5] flex items-center justify-center relative overflow-hidden">
            <div class="text-center p-8">
              <svg class="w-16 h-16 mx-auto mb-4 text-slate-600" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
              <p class="text-slate-500 text-sm">Founder photo</p>
            </div>
            <div class="absolute bottom-6 left-6 right-6">
              <div class="bg-white/10 backdrop-blur-sm rounded-sm p-4">
                <p class="font-serif text-white text-lg font-semibold">Sabine</p>
                <p class="text-slate-300 text-xs mt-1">Workplace Risk &amp; Ergonomics Specialist</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 md:py-28 bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="section-label mb-4">Why Work With Us</p>
        <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brand-dark leading-tight">What Makes Our Approach Different</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">Audit-Ready Outputs</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Every report is structured to withstand regulatory scrutiny, insurance review, and legal challenge.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">Bilingual Expertise</h3>
          <p class="text-slate-600 text-sm leading-relaxed">Native-level English and German capability. We navigate UK, Irish, and DACH compliance requirements with equal fluency.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">SME-Focused</h3>
          <p class="text-slate-600 text-sm leading-relaxed">We work exclusively with SMEs of 20 to 150 employees. Our services are proportionate, practical, and priced accordingly.</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-brand-cream rounded-sm flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-brand-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="font-serif text-lg font-semibold text-brand-dark mb-2">Fully Remote Delivery</h3>
          <p class="text-slate-600 text-sm leading-relaxed">All services are delivered remotely. No travel costs, no scheduling delays. Designed for the way modern SMEs actually work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-20 bg-brand-dark">
    <div class="container-narrow text-center">
      <p class="section-label text-brand-accentLight mb-4">Ready to Get Started?</p>
      <h2 class="font-serif text-3xl md:text-4xl font-semibold text-white leading-tight mb-6">
        Let us assess your compliance position before your insurer or regulator does.
      </h2>
      <p class="text-slate-400 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        Book a no-obligation consultation to discuss your remote workforce risk profile and the most appropriate service for your business.
      </p>
      <a href="/contact" class="btn-primary text-base px-8 py-4">Book a Consultation</a>
    </div>
  </section>

</BaseLayout>
