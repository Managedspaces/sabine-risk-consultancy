---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOOLS_APP_URL } from '../../config/site';

const title = "Risk Assessment Builder Tool | Sabine Salowsky";
const description = "Build a bespoke, audit-ready workplace risk assessment. Select hazard categories, rate likelihood and severity using the 5×5 risk matrix, and generate reports.";

const canonicalUrl = "https://sabine-risk-consultancy.netlify.app/tools/risk-assessment-builder";
const hreflangPairs = [
  { lang: "en", url: "https://sabine-risk-consultancy.netlify.app/tools/risk-assessment-builder" }
];

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Tools", url: "/tools" },
  { name: "Risk Assessment Builder", url: "/tools/risk-assessment-builder" }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Risk Assessment Builder Tool",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "WebBrowser",
  "description": "Build a bespoke, audit-ready workplace risk assessment using a 5x5 matrix.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  hreflangPairs={hreflangPairs}
  breadcrumbs={breadcrumbs}
  schema={schema}
>

  <section class="pt-32 pb-20 bg-brand-dark text-white">
    <div class="container-narrow">
      <a href="/tools" class="inline-block text-brand-accentLight hover:text-white transition-colors mb-8">&larr; Back to all tools</a>
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="flex-1">
          <p class="section-label text-brand-accentLight mb-4">Professional Tool</p>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-tight mb-6">
            Risk Assessment Builder
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed mb-8">
            Build a bespoke, audit-ready workplace risk assessment. Select hazard categories, rate likelihood and severity using the standard 5×5 risk matrix, and assign control measures.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-4">Launch Builder</a>
          </div>
        </div>
        <div class="w-full md:w-1/3 bg-white/5 border border-white/10 rounded-sm p-8">
          <h3 class="font-serif text-xl font-semibold mb-4">Tool Specifications</h3>
          <ul class="space-y-4 text-slate-300">
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Hazard Types</span> <span class="font-semibold text-white">9</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Methodology</span> <span class="font-semibold text-white">5×5 Matrix</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Jurisdictions</span> <span class="font-semibold text-white">6</span>
            </li>
            <li class="flex justify-between pb-2">
              <span>Output</span> <span class="font-semibold text-white">PDF Report</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6">A structured approach to risk</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-10">
          This tool replaces unstructured spreadsheets with a rigorous, standard-aligned methodology. It forces the user to evaluate risk objectively before and after control measures are applied.
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">9 Hazard Categories</h3>
            <p class="text-slate-600">Pre-populated hazard templates including Slips & Trips, Manual Handling, Fire, Electrical, Chemicals, Height, Stress, and DSE, plus custom entries.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">The 5×5 Risk Matrix</h3>
            <p class="text-slate-600">Objectively score the likelihood (1-5) and severity (1-5) of an incident occurring, generating a clear RAG (Red, Amber, Green) risk rating.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">Control Measures & Residual Risk</h3>
            <p class="text-slate-600">Document the exact controls put in place to mitigate the hazard, and automatically calculate the new, lower residual risk score.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">Audit-Ready Output</h3>
            <p class="text-slate-600">Generates a cleanly formatted, date-stamped PDF report that can be filed directly into your compliance documentation system.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-cream">
    <div class="container-narrow">
      <div class="bg-white p-10 md:p-16 rounded-sm shadow-sm border border-slate-200 text-center">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-4">Complex environment?</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8 max-w-2xl mx-auto">
          If you are dealing with multiple hazard types across a growing organisation, self-assessment may not be enough to ensure compliance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">Try the Builder</a>
          <a href="/services/sme-risk-audit" class="px-6 py-3 border-2 border-brand-dark text-brand-dark font-semibold rounded-sm hover:bg-brand-dark hover:text-white transition-colors">Request a Professional Audit</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
