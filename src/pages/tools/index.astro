---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOOLS_APP_URL } from '../../config/site';

const title = "Workplace Wellbeing & Risk Assessment Tools | Sabine Salowsky";
const description = "Professional-grade self-assessment tools for ergonomic risk, home office setup, and psychosocial wellbeing. Designed by specialists, built for SMEs.";

const canonicalUrl = "https://sabine-risk-consultancy.netlify.app/tools";
const hreflangPairs = [
  { lang: "en", url: "https://sabine-risk-consultancy.netlify.app/tools" }
];

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Tools", url: "/tools" }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Workplace Risk Assessment Tools",
  "description": "A suite of professional self-assessment tools for workplace ergonomics and wellbeing.",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "url": "https://sabine-risk-consultancy.netlify.app/tools/ergonomic-risk-assessment"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "url": "https://sabine-risk-consultancy.netlify.app/tools/home-office-assessment"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "url": "https://sabine-risk-consultancy.netlify.app/tools/psychosocial-risk-assessment"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "url": "https://sabine-risk-consultancy.netlify.app/tools/risk-assessment-builder"
    }
  ]
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  hreflangPairs={hreflangPairs}
  breadcrumbs={breadcrumbs}
  schema={schema}
>

  <!-- Hero Section -->
  <section class="relative pt-32 pb-20 bg-brand-dark text-white overflow-hidden" style="min-height:420px">
    <div class="absolute inset-0">
      <img src={`${import.meta.env.BASE_URL}/images/hero-tools.webp`} alt="" role="presentation" class="w-full h-full object-cover" loading="eager" fetchpriority="high" width="1920" height="1080" />
      <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(10,36,99,0.92) 0%, rgba(10,36,99,0.78) 60%, rgba(10,36,99,0.60) 100%);"></div>
    </div>
    <div class="container-narrow relative">
      <p class="section-label text-brand-accentLight mb-4">Professional Assessment Tools</p>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold leading-tight mb-6">
        Evaluate your workplace.<br/>
        <span class="text-brand-accent">Understand the reality.</span>
      </h1>
      <p class="text-xl text-slate-300 leading-relaxed mb-10 max-w-2xl">
        We have codified our specialist methodology into a suite of professional self-assessment tools. Use them to baseline your team's current setup, identify immediate risks, and generate compliance-ready documentation.
      </p>
    </div>
  </section>

  <!-- Tools Grid Section -->
  <section class="py-20 bg-brand-cream">
    <div class="container-narrow">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <!-- Tool 1: Ergonomic -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">29 Questions • 6 Categories</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Ergonomic Risk Assessment</h2>
            <p class="text-slate-600 leading-relaxed">
              Evaluate office workstation ergonomics across six dimensions of physical health, from posture and equipment to environmental factors.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/tools/ergonomic-risk-assessment`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Read the guide &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Launch Tool &#8599;</a>
          </div>
        </div>

        <!-- Tool 2: Home Office -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">30 Questions • 6 Categories</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Home Office Assessment</h2>
            <p class="text-slate-600 leading-relaxed">
              Assess the safety and suitability of remote workspaces, covering electrical safety, fire hazards, and work organisation.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/tools/home-office-assessment`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Read the guide &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Launch Tool &#8599;</a>
          </div>
        </div>

        <!-- Tool 3: Psychosocial -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">20 Questions • 5 Categories</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Psychosocial Risk Assessment</h2>
            <p class="text-slate-600 leading-relaxed">
              Measure stress, workload, role clarity, and work-life balance. Generates reports aligned with ISO 45003 standards.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/tools/psychosocial-risk-assessment`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Read the guide &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Launch Tool &#8599;</a>
          </div>
        </div>

        <!-- Tool 4: Builder -->
        <div class="bg-white rounded-sm border border-slate-200 p-10 shadow-sm flex flex-col h-full transition-shadow hover:shadow-md">
          <div class="mb-6">
            <span class="inline-block px-3 py-1 bg-brand-cream text-brand-dark text-xs font-semibold uppercase tracking-wider rounded-sm mb-4">9 Hazard Types • 5×5 Matrix</span>
            <h2 class="font-serif text-2xl font-semibold text-brand-dark mb-3">Risk Assessment Builder</h2>
            <p class="text-slate-600 leading-relaxed">
              Build a bespoke, audit-ready workplace risk assessment using a standard 5×5 matrix to assign and document control measures.
            </p>
          </div>
          <div class="mt-auto pt-6 border-t border-slate-100 flex gap-4">
            <a href={`${import.meta.env.BASE_URL}/tools/risk-assessment-builder`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Read the guide &rarr;</a>
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="ml-auto text-brand-dark font-semibold hover:text-brand-accent transition-colors">Launch Tool &#8599;</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Methodology Note -->
  <section class="py-20 bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6">Built on clinical science. Not just checklists.</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          These tools were designed by Sabine Salowsky, drawing on her background in Occupational Therapy (B.Sc.) and Physiological Psychology (Dipl.-Biol.). They do not just ask if a monitor is at the right height — they evaluate the holistic working environment to identify the root causes of fatigue and productivity loss.
        </p>
        <a href={`${import.meta.env.BASE_URL}/about`} class="text-brand-accent font-semibold hover:text-brand-dark transition-colors">Read about our methodology &rarr;</a>
      </div>
    </div>
  </section>

</BaseLayout>
