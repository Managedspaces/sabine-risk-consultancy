---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TOOLS_APP_URL } from '../../config/site';

const title = "Ergonomic Risk Assessment Tool | Sabine Salowsky";
const description = "A professional self-assessment tool to evaluate office workstation ergonomics across six dimensions of physical health. Generate compliance-ready reports instantly.";

const canonicalUrl = "https://sabine-risk-consultancy.netlify.app/tools/ergonomic-risk-assessment";
const hreflangPairs = [
  { lang: "en", url: "https://sabine-risk-consultancy.netlify.app/tools/ergonomic-risk-assessment" }
];

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Tools", url: "/tools" },
  { name: "Ergonomic Risk Assessment", url: "/tools/ergonomic-risk-assessment" }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Ergonomic Risk Assessment Tool",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "WebBrowser",
  "description": "Evaluate office workstation ergonomics across six dimensions of physical health.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  hreflangPairs={hreflangPairs}
  breadcrumbs={breadcrumbs}
  schema={schema}
>

  <section class="pt-32 pb-20 bg-brand-dark text-white">
    <div class="container-narrow">
      <a href={`${import.meta.env.BASE_URL}/tools`} class="inline-block text-brand-accentLight hover:text-white transition-colors mb-8">&larr; Back to all tools</a>
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="flex-1">
          <p class="section-label text-brand-accentLight mb-4">Self-Assessment Tool</p>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-tight mb-6">
            Ergonomic Risk Assessment
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed mb-8">
            Evaluate your office workstation ergonomics across six dimensions of physical health. A 29-question structured assessment designed to identify the root causes of musculoskeletal discomfort.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-base px-8 py-4">Launch Assessment Tool</a>
          </div>
        </div>
        <div class="w-full md:w-1/3 bg-white/5 border border-white/10 rounded-sm p-8">
          <h3 class="font-serif text-xl font-semibold mb-4">Tool Specifications</h3>
          <ul class="space-y-4 text-slate-300">
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Questions</span> <span class="font-semibold text-white">29</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Categories</span> <span class="font-semibold text-white">6</span>
            </li>
            <li class="flex justify-between border-b border-white/10 pb-2">
              <span>Jurisdictions</span> <span class="font-semibold text-white">6</span>
            </li>
            <li class="flex justify-between pb-2">
              <span>Time required</span> <span class="font-semibold text-white">5–10 mins</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-6">What this tool measures</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-10">
          Most basic DSE checklists only look at the physical hardware — is the monitor at eye level, is the chair adjustable? This tool goes deeper, evaluating the interaction between the person, the equipment, and the environment.
        </p>

        <div class="space-y-8">
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">1. Workstation Equipment</h3>
            <p class="text-slate-600">Assesses the suitability, adjustability, and correct usage of chairs, desks, monitors, and input devices.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">2. Posture & Body Positioning</h3>
            <p class="text-slate-600">Evaluates neutral joint alignment, supported sitting postures, and the presence of awkward or sustained reaches.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">3. Work Patterns & Screen Time</h3>
            <p class="text-slate-600">Analyses micro-breaks, task variation, and the ratio of static sitting to dynamic movement throughout the day.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">4. Environmental Factors</h3>
            <p class="text-slate-600">Checks lighting quality, glare, temperature, and noise levels — factors that heavily influence cognitive fatigue.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">5. Vision & Eye Strain</h3>
            <p class="text-slate-600">Measures focal distance, screen contrast, and visual resting habits to prevent computer vision syndrome.</p>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brand-dark mb-2">6. Psychosocial Workload</h3>
            <p class="text-slate-600">A brief baseline of cognitive load and stress, as these directly amplify physical musculoskeletal tension.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-cream">
    <div class="container-narrow">
      <div class="bg-white p-10 md:p-16 rounded-sm shadow-sm border border-slate-200 text-center">
        <h2 class="font-serif text-3xl font-semibold text-brand-dark mb-4">Need professional interpretation?</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-8 max-w-2xl mx-auto">
          The self-assessment tool provides an excellent baseline. If the report highlights high-risk areas, or if an employee is already experiencing pain, you need a specialist.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={TOOLS_APP_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">Take the Free Assessment</a>
          <a href={`${import.meta.env.BASE_URL}/services/remote-ergonomic-assessment`} class="px-6 py-3 border-2 border-brand-dark text-brand-dark font-semibold rounded-sm hover:bg-brand-dark hover:text-white transition-colors">Book a Professional Assessment</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
